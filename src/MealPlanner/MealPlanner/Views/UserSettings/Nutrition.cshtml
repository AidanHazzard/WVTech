@model MealPlanner.ViewModels.NutritionSettingsViewModel

@{
    ViewData["Title"] = "Nutrition Goals";
}

<div class="back1 backHasButton">
    <h2 class="back1Title">Nutrition Goals</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    <form asp-action="Nutrition" method="post">
        @Html.AntiForgeryToken()

        <h2 class="back1Title left">
            <span>Calorie Target:</span>
            <input asp-for="CalorieTarget" class="back2-textbox" type="number" placeholder="Enter Calorie Target" min="0" max="32767" step="1" required>
        </h2>

        <h2 class="back1Title left">
            <span>Protein Target (g):</span>
            <input asp-for="ProteinTarget" class="back2-textbox" type="number" placeholder="Enter Protein Target" min="0" max="32767" step="1" required>
        </h2>

        <h2 class="back1Title left">
            <span>Carb Target (g):</span>
            <input asp-for="CarbTarget" class="back2-textbox" type="number" placeholder="Enter Carb Target" min="0" max="32767" step="1" required>
        </h2>

        <h2 class="back1Title left">
            <span>Fat Target (g):</span>
            <input asp-for="FatTarget" class="back2-textbox" type="number" placeholder="Enter Fat Target" min="0" max="32767" step="1" required>
        </h2>

        <button class="buttonBlue">
            <h2 class="buttonText">Finish</h2>
        </button>
    </form>
</div>