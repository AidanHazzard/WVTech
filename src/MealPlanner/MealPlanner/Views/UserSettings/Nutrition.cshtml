@model MealPlanner.ViewModels.NutritionSettingsViewModel

@{
    ViewData["Title"] = "Nutrition Goals";
}

<div class="container mt-4">
    <div class="p-4 rounded-4" style="background-color: #d9d9d9;">
        <h2 class="text-center mb-4">Nutrition Goals</h2>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success text-center">
                @TempData["Message"]
            </div>
        }

        <form asp-action="Nutrition" method="post">
            @Html.AntiForgeryToken()

            <div class="p-4 rounded-4" style="background-color: #efefef;">
                <div class="mb-4">
                    <label class="form-label fs-5">Calorie Target</label>
                    <input asp-for="CalorieTarget" class="form-control rounded-4" type="number" />
                </div>

                <div class="mb-4">
                    <label class="form-label fs-5">Protein Target (g)</label>
                    <input asp-for="ProteinTarget" class="form-control rounded-4" type="number" />
                </div>

                <div class="mb-4">
                    <label class="form-label fs-5">Carb Target (g)</label>
                    <input asp-for="CarbTarget" class="form-control rounded-4" type="number" />
                </div>

                <div class="mb-0">
                    <label class="form-label fs-5">Fat Target (g)</label>
                    <input asp-for="FatTarget" class="form-control rounded-4" type="number" />
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4 rounded-4">Save</button>
            </div>
        </form>
    </div>
</div>