@model MealPlanner.ViewModels.NutritionSettingsViewModel

@{
    ViewData["Title"] = "Nutrition Goals";
}

<h2>Nutrition Goals</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<form asp-action="Nutrition" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Calorie Target</label>
        <input asp-for="CalorieTarget" class="form-control" type="number" />
    </div>

    <div class="mb-3">
        <label class="form-label">Protein Target (g)</label>
        <input asp-for="ProteinTarget" class="form-control" type="number" />
    </div>

    <div class="mb-3">
        <label class="form-label">Carb Target (g)</label>
        <input asp-for="CarbTarget" class="form-control" type="number" />
    </div>

    <div class="mb-3">
        <label class="form-label">Fat Target (g)</label>
        <input asp-for="FatTarget" class="form-control" type="number" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>