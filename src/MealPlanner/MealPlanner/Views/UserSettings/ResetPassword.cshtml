@using MealPlanner.ViewModels
@using Microsoft.AspNetCore.Identity
@inject SignInManager<MealPlanner.Models.User> SignInManager
@model UserSettingsResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />

<div class="settings-layout">

    <!-- ── Sidebar (same as Index, reset-password is active) ── -->
    <aside class="settings-sidebar">

        <a class="settings-nav-item" asp-controller="UserSettings" asp-action="Index" asp-route-section="profile">
            <svg class="settings-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            Profile
        </a>

        <a class="settings-nav-item" asp-controller="UserSettings" asp-action="Index" asp-route-section="nutrition">
            <svg class="settings-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
                <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
                <line x1="6" y1="1" x2="6" y2="4"/>
                <line x1="10" y1="1" x2="10" y2="4"/>
                <line x1="14" y1="1" x2="14" y2="4"/>
            </svg>
            Nutrition Goals
        </a>

        <a class="settings-nav-item" asp-controller="UserSettings" asp-action="Index" asp-route-section="dietary">
            <svg class="settings-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Dietary Restrictions
        </a>

        <a class="settings-nav-item" asp-controller="UserSettings" asp-action="Index" asp-route-section="food">
            <svg class="settings-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 11l19-9-9 19-2-8-8-2z"/>
            </svg>
            Food Preferences
        </a>

        <a class="settings-nav-item" asp-controller="UserSettings" asp-action="Index" asp-route-section="appearance">
            <svg class="settings-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            Appearance
        </a>

        <div class="settings-nav-divider"></div>

        <a class="settings-nav-item active" asp-controller="UserSettings" asp-action="ResetPassword">
            <svg class="settings-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            Reset Password
        </a>

        @if (SignInManager.IsSignedIn(User))
        {
            <form method="post" asp-area="" asp-controller="Login" asp-action="Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="settings-nav-item logout">
                    <svg class="settings-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Logout
                </button>
            </form>
        }
    </aside>

    <!-- ── Reset password card ───────────────────────────── -->
    <main class="settings-content">

        @if (!string.IsNullOrEmpty(ViewBag.StatusMessage as string))
        {
            <div class="settings-success">@ViewBag.StatusMessage</div>
        }

        <div class="settings-card">
            <div class="settings-card-header">
                <div class="settings-card-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                </div>
                <span class="settings-card-title">Reset Password</span>
            </div>
            <div class="settings-card-body">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:12px"></div>

                <form asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="reset-pw-field">
                        <label class="reset-pw-label" asp-for="Password">Current password</label>
                        <input asp-for="Password" type="password" class="reset-pw-input" />
                        <span asp-validation-for="Password" class="text-danger" style="font-size:11px"></span>
                    </div>

                    <div class="reset-pw-field">
                        <label class="reset-pw-label" asp-for="NewPassword">New password</label>
                        <input asp-for="NewPassword" type="password" class="reset-pw-input" />
                        <span asp-validation-for="NewPassword" class="text-danger" style="font-size:11px"></span>
                    </div>

                    <div class="reset-pw-field">
                        <label class="reset-pw-label" asp-for="ConfirmPassword">Confirm new password</label>
                        <input asp-for="ConfirmPassword" type="password" class="reset-pw-input" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:11px"></span>
                    </div>

                    <button type="submit" class="settings-save-btn" style="margin-top:4px">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Change password
                    </button>
                </form>
            </div>
        </div>

    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
