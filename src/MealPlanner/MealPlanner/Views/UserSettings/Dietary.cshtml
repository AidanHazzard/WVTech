@model MealPlanner.ViewModels.DietarySettingsViewModel

@{
    ViewData["Title"] = "Dietary Restrictions";
}

    <div class="back1 backHasButton">
        <a class="btn btn-secondary px-4 rounded-4" asp-action="Index">Back</a>
        <h1 class="back1Title">Dietary Restrictions</h1>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success text-center">
                @TempData["Message"]
            </div>
        }

        <form asp-action="Dietary" method="post">
            @Html.AntiForgeryToken()

            <div class="back2">
                <div class="row">
                    @for (int i = 0; i < Model.Restrictions.Count; i++)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="form-check fs-5">
                                <input class="form-check-input" type="checkbox" asp-for="Restrictions[i].IsSelected" />
                                <input type="hidden" asp-for="Restrictions[i].DietaryRestrictionId" />
                                <input type="hidden" asp-for="Restrictions[i].Name" />
                                <label>@Model.Restrictions[i].Name</label>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <button type="submit" class="buttonBlue">
                <h2 class="ButtonText">Save</h2>
            </button>
        </form>
    </div>
