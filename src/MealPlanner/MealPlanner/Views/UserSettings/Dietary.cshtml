@model MealPlanner.ViewModels.DietarySettingsViewModel

@{
    ViewData["Title"] = "Dietary Restrictions";
}

<div class="container mt-4">
    <h2>Dietary Restrictions</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success mt-3">@TempData["Message"]</div>
    }

    <form asp-action="Dietary" method="post" class="mt-3">
        @Html.AntiForgeryToken()

        <div class="row">
            @for (int i = 0; i < Model.Restrictions.Count; i++)
            {
                <div class="col-md-6">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" asp-for="Restrictions[i].IsSelected" />
                        <input type="hidden" asp-for="Restrictions[i].DietaryRestrictionId" />
                        <input type="hidden" asp-for="Restrictions[i].Name" />
                        <label class="form-check-label">@Model.Restrictions[i].Name</label>
                    </div>
                </div>
            }
        </div>

        <button type="submit" class="btn btn-primary mt-3">Save</button>
        <a class="btn btn-secondary mt-3" asp-action="Index">Back</a>
    </form>
</div>