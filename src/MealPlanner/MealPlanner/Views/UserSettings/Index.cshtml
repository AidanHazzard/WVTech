@model MealPlanner.ViewModels.FoodPreferenceViewModel

@{
    ViewData["Title"] = "User Settings";
}

<div class="back1">
    <h2 class="back1Title">User Settings</h2>

    <div class="list-group mt-3" style="border-radius: 20px 20px 0 0;">
        <a class="list-group-item list-group-item-action linkListBack"
            asp-controller="UserSettings" asp-action="Dietary">
            <h5 class="baseText">Dietary Restrictions</h5>
        </a>

        <a class="list-group-item list-group-item-action linkListBack"
        asp-controller="UserSettings" asp-action="Nutrition">
            <h5 class="baseText">Nutrition Goals</h5>
        </a>

        <div class="list-group-item linkListBack d-flex justify-content-between align-items-center">
            <h5 class="baseText mb-0">Toggle Dark Mode</h5>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="themeToggle"
                       style="cursor:pointer; width:3em; height:1.5em;">
            </div>
        </div>

        @if (User.IsInRole("Admin"))
            {
                <a class="list-group-item list-group-item-action linkListBack"
                asp-controller="Home" asp-action="Admin">
                    <h5 class="baseText">Admin</h5>
                </a>
            }
            else if (User.IsInRole("User"))
            {
                <a class="list-group-item list-group-item-action linkListBack"
                asp-controller="Favorites" asp-action="Index">
                    <h5 class="baseText">Favorites</h5>
                </a>
            }

        <a class="list-group-item list-group-item-action linkListBack"
        asp-controller="UserSettings" asp-action="ResetPassword">
            <h5 class="baseText">Reset Password</h5>
        </a>
        <partial name="_LoginPartial" />
    </div>
</div>

<div class="back1 mt-3">
    <h2 class="back1Title">Food Preferences</h2>

    @if (Model.CurrentPreferences.Count > 0)
    {
        <div class="back2">
            <h2 class="back1Title">Your Saved Preferences</h2>
            <div class="d-flex flex-wrap gap-1">
                @foreach (var pref in Model.CurrentPreferences)
                {
                    <form asp-action="RemoveFoodPreference" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="tagName" value="@pref" />
                        <button type="submit" class="food-pref-item tag-pill badge rounded-pill recipe-tag food-pref-remove-btn"
                                data-tag-name="@pref" title="Remove @pref">
                            @pref
                        </button>
                    </form>
                }
            </div>
        </div>
    }

    <form asp-action="SaveFoodPreferences" method="post" id="food-pref-form">
        @Html.AntiForgeryToken()

        <div class="back2 backHasButton">
            <h2 class="back1Title">Add Preferences</h2>

            <select id="food-pref-select" class="back2-textbox mb-2">
                <option value="">-- Select a Preference --</option>
                @foreach (var tag in Model.AvailableTags)
                {
                    <option value="@tag">@tag</option>
                }
            </select>

            <div class="tag-input-wrapper mb-2">
                <input type="text" id="food-pref-custom-input" class="back2-textbox"
                       placeholder="Or type a custom preference..." />
                <button type="button" id="food-pref-add-btn" class="add-tag-btn buttonGreenInline">
                    <h4 class="buttonText">Add</h4>
                </button>
            </div>

            <div id="food-pref-pending-container" class="d-flex flex-wrap gap-1 mb-2"></div>

            <button type="submit" id="food-pref-save-btn" class="buttonGreen">
                <h2 class="buttonText">Save Preferences</h2>
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/themeToggle.js"></script>
    <script src="~/js/foodPreference.js"></script>
}
