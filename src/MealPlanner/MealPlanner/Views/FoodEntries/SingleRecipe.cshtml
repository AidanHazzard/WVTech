@model MealPlanner.ViewModels.RecipeViewModel
@using MealPlanner.Models

<link rel="stylesheet" href="~/css/singleRecipe.css" asp-append-version="true" />

<a href="javascript:history.back()" class="page-back-link">
    <i class="ti ti-arrow-left"></i>
    Back
</a>

<div id="recipe" class="sr-page" recipe-id="@Model.Id">

    @if (Model.Tags.Any())
    {
        <div class="sr-tags">
            @foreach (var tag in Model.Tags)
            {
                <span class="sr-tag">@tag</span>
            }
        </div>
    }

    <div class="sr-grid">

        <!-- ── Left column ─────────────────────────── -->
        <div class="sr-left">

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" class="sr-image" />
            }
            else
            {
                <div class="sr-image-placeholder">
                    <i class="ti ti-tools-kitchen-2"></i>
                </div>
            }

            <!-- Nutrition card -->
            <div class="sr-card">
                <div class="sr-card-title">
                    <span class="sr-card-icon"><i class="ti ti-chart-bar"></i></span>
                    <span class="sr-card-label">Nutrition</span>
                </div>
                @{
                    bool hasNutrition = !(Model.Calories == 0 && Model.Protein == 0 && Model.Carbs == 0 && Model.Fat == 0);
                }
                @if (hasNutrition)
                {
                    <div class="sr-nutrition-rows">
                        <div class="sr-nutrition-row">
                            <span class="sr-nut-label">Calories</span>
                            <span class="sr-nut-value">@Model.Calories kcal</span>
                        </div>
                        <div class="sr-nutrition-row">
                            <span class="sr-nut-label">Protein</span>
                            <span class="sr-nut-value">@Model.Protein g</span>
                        </div>
                        <div class="sr-nutrition-row">
                            <span class="sr-nut-label">Carbs</span>
                            <span class="sr-nut-value">@Model.Carbs g</span>
                        </div>
                        <div class="sr-nutrition-row">
                            <span class="sr-nut-label">Fat</span>
                            <span class="sr-nut-value">@Model.Fat g</span>
                        </div>
                    </div>
                }
                else
                {
                    <p class="sr-empty-text">No nutrition information available.</p>
                }
            </div>

            <!-- Ingredients card -->
            <div class="sr-card">
                <div class="sr-card-title">
                    <span class="sr-card-icon"><i class="ti ti-bowl-chopsticks"></i></span>
                    <span class="sr-card-label">Ingredients</span>
                </div>
                <div class="sr-ingredient-rows">
                    @for (int i = 0; i < Model.Ingredients.Count; i++)
                    {
                        <div class="sr-ingredient-row">
                            <span class="sr-ing-name">@Model.Ingredients[i]</span>
                            <span class="sr-ing-qty">@Model.IngredientAmounts[i] @Model.IngredientMeasurements[i]</span>
                        </div>
                    }
                </div>
            </div>

        </div>

        <!-- ── Right column ────────────────────────── -->
        <div class="sr-right">

            <div class="sr-header">
                <h1 class="sr-recipe-name">@Model.Name</h1>
                <div class="sr-vote-row">
                    @{
                        string voterPercentage = Model.VotePercentage != null
                            ? $"{(int)(Model.VotePercentage.Value * 100)}%"
                            : "0%";
                    }
                    <span id="votePercent" class="sr-match-pct">@voterPercentage</span>
                    <button id="thumbs-up"
                            class="vote sr-vote-btn @(Model.UserVote == UserVoteType.UpVote ? "sr-active" : "")"
                            vote-type="@(Model.UserVote == UserVoteType.UpVote ? "NoVote" : "UpVote")"
                            base-vote="UpVote"
                            type="button"
                            aria-label="Thumbs up">
                        <i class="ti ti-thumb-up"></i>
                    </button>
                    <button id="thumbs-down"
                            class="vote sr-vote-btn @(Model.UserVote == UserVoteType.DownVote ? "sr-active" : "")"
                            vote-type="@(Model.UserVote == UserVoteType.DownVote ? "NoVote" : "DownVote")"
                            base-vote="DownVote"
                            type="button"
                            aria-label="Thumbs down">
                        <i class="ti ti-thumb-down"></i>
                    </button>
                </div>
            </div>

            <!-- Instructions card -->
            <div class="sr-card">
                <div class="sr-card-title">
                    <span class="sr-card-icon"><i class="ti ti-list"></i></span>
                    <span class="sr-card-label">Instructions</span>
                </div>
                <p class="sr-instructions-text">@Model.Directions</p>
            </div>

            @if (Model.IsOwned)
            {
                <div class="sr-footer">
                    <a href="/FoodEntries/EditRecipe/@Model.Id" class="sr-edit-btn">
                        <i class="ti ti-edit"></i>
                        Edit Recipe
                    </a>
                </div>
            }

        </div>

    </div>

</div>

@section Scripts {
    <script type="module" src="~/js/recipeVote.js"></script>
}
