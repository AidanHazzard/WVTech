@model MealPlanner.ViewModels.RecipeViewModel

<link rel="stylesheet" href="~/css/AddNewRecipe.css" asp-append-version="true" />


<div class="back1 backHasButton">
    <h1 class="back1Title">Edit Recipe</h1>

<form asp-controller="FoodEntries" asp-action="RecipeEditFinished" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">

        <h2 class="back1Title left">
            <span>Name:</span>
            <input class="back2-textbox" type="text" placeholder="Enter Recipe Name" asp-for="Name" value="@Model.Name" required>
            </h2>


            <div class="back2 backHasButton" id="AppendHere"
                 data-measurements="@System.Text.Json.JsonSerializer.Serialize(Model.Measurements.Select(m => new { value = m.Name, label = m.Abbreviation }))">
                <h2 class="back1Title">Ingredients</h2>
                @for (int i = 0; i < Model.Ingredients.Count; i++)
                {
                    <div class="row input-wrapper">
                        <div class="row">
                            <input type="text" class="col-1 back2-textbox-partial mx-1" name="IngredientAmounts" placeholder="e.g. 1/2" value="@Model.IngredientAmounts[i]">
                            <select class="col-2 back2-textbox-partial mx-1" name="IngredientMeasurements">
                                <option value="">Select</option>
                                @foreach (var m in Model.Measurements)
                                {
                                    <option value="@m.Name" selected="@(Model.IngredientMeasurements[i] == m.Name ? "selected" : null)">@m.Abbreviation</option>
                                }
                            </select>
                            <input type="text" class="col back2-textbox-partial mx-1" placeholder="Enter Ingredient" name="Ingredients" value="@Model.Ingredients[i]" required>
                        </div>
                        <button type="button" class="deleteButton">
                            <img src="/images/icons/delete.png" alt="delete" class="deleteImage">
                        </button>
                    </div>
                }

                <button class="buttonGreen" id="buttonAppend">
                    <h2 class="buttonText">Add Ingredient</h2>
                </button>
            </div>

            <div class="back2">
                <h2 class="back1Title">Instructions</h2>
                <textarea class="back2-textbox instructionsBox" placeholder="Enter Instructions" asp-for="Directions" value="@Model.Directions" required></textarea>
            </div>

            <div class="back2">
                <h2 class="back1Title">Nutrients</h2>
                
                <h2 class="back1Title left">
                    <span>Calories:</span>
                    <input type="number" class="back2-textbox" placeholder="Enter Calories" min="0" max="32767" step="1" asp-for="Calories" value="@Model.Calories" required>
                </h2>

                <h2 class="back1Title left">
                    <span>Protein:</span>
                    <input type="number" class="back2-textbox" placeholder="Enter Protein" min="0" max="32767" step="1" asp-for="Protein" value="@Model.Protein" required>
                </h2>

                <h2 class="back1Title left">
                    <span>Carbs:</span>
                    <input type="number" class="back2-textbox" placeholder="Enter Carbs" min="0" max="32767" step="1" asp-for="Carbs" value="@Model.Carbs" required>
                </h2>

                <h2 class="back1Title left">
                    <span>Fat:</span>
                    <input type="number" class="back2-textbox" placeholder="Enter Fat" min="0" max="32767" step="1" asp-for="Fat" value="@Model.Fat" required>
                </h2>
            </div>

            @await Html.PartialAsync("_TagSelector")

            <div class="back2">
                <h2 class="back1Title">Recipe Image</h2>
                <input type="hidden" asp-for="ImageUrl" />
                <div class="file-input-wrapper back2-textbox">
                    <label for="imageFile" class="file-browse-btn buttonGreenInline">
                        <h4 class="buttonText">Browse</h4>
                    </label>
                    <span class="file-name-display">No file chosen</span>
                    <input type="file" id="imageFile" name="ImageFile" accept="image/*" style="display:none;" />
                    <button type="button" class="deleteButton file-remove-btn" id="removeImageBtn" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")">
                        <img src="/images/icons/delete.png" alt="remove" class="deleteImage">
                    </button>
                </div>
                <input type="hidden" id="removeImageHidden" name="RemoveImage" value="false" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="Current recipe image" class="image-preview" style="display:block;" />
                }
                <img id="imagePreview" src="" alt="Image preview" class="image-preview" />
            </div>

            <button class="buttonBlue" type="submit">
                <h2 class="buttonText">Finish</h2>
            </button>
    </form>
</div>


@section Scripts {
    <script src="~/js/newrecipepage.js"></script>
}