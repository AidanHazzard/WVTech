@model MealPlanner.ViewModels.NutritionSummaryViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Nutrition Summary";
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var allDaysJson  = JsonSerializer.Serialize(Model.AllDays, jsonOptions);
    var targetsJson  = JsonSerializer.Serialize(Model.DailyTargets, jsonOptions);
}

<link rel="stylesheet" href="~/css/nutritionSummary.css" asp-append-version="true" />

<a href="javascript:history.back()" class="page-back-link">
    <i class="ti ti-arrow-left"></i>
    Back
</a>

<!-- Page Heading -->
<div class="report-heading">
    <h1 class="report-title">Nutrition summary</h1>
    <span class="report-date-label" id="report-date-range">–</span>
</div>

<!-- Segmented Control -->
<div class="segmented-wrap">
    <div class="segmented-control">
        <button type="button"
                class="segmented-btn @(Model.ActiveTab == "weekly" ? "active" : "")"
                id="tab-weekly">Weekly</button>
        <button type="button"
                class="segmented-btn @(Model.ActiveTab == "monthly" ? "active" : "")"
                id="tab-monthly">Monthly</button>
    </div>
</div>

<!-- Macro Summary Row -->
<div class="macro-grid">
    @foreach (var macro in new[] {
        ("calories", "Calories", "kcal", "var(--macro-calories)"),
        ("protein",  "Protein",  "g",    "var(--macro-protein)"),
        ("carbs",    "Carbs",    "g",    "var(--macro-carbs)"),
        ("fat",      "Fat",      "g",    "var(--macro-fats)")
    })
    {
        <div class="macro-card">
            <div class="macro-card-label" style="color: @macro.Item4;">@macro.Item2</div>
            <div class="macro-card-value"><span id="card-@macro.Item1-actual">–</span></div>
            <div class="macro-card-goal"><span id="card-@macro.Item1-goal">–</span></div>
            <div class="macro-card-bar-track">
                <div id="card-@macro.Item1-bar"
                     class="macro-card-bar-fill"
                     style="width: 0%; background-color: @macro.Item4;"></div>
            </div>
        </div>
    }
</div>

<!-- Chart + Today's Macros row -->
<div class="chart-row">

    <!-- Bar Chart Card -->
    <div class="chart-card">
        <div class="chart-card-title">Daily calories vs goal</div>
        <canvas id="barChart"></canvas>
        <div class="chart-legend">
            <div class="chart-legend-item">
                <span class="chart-legend-dash"></span>
                Goal
            </div>
            <div class="chart-legend-item">
                <span class="chart-legend-swatch" style="background: var(--macro-calories);"></span>
                Met goal
            </div>
            <div class="chart-legend-item">
                <span class="chart-legend-swatch" style="background: #E24B4A;"></span>
                Below 70%
            </div>
            <div class="chart-legend-item">
                <span class="chart-legend-swatch" style="background: rgba(160,160,160,0.35);"></span>
                No check-offs
            </div>
        </div>
    </div>

    <!-- Today's Macros Card -->
    <div class="todays-macros-card">
        <div class="tm-title">Today's macros</div>

        <div class="tm-row">
            <div class="tm-row-header">
                <span class="tm-label" style="color: var(--macro-calories);">Calories</span>
                <span class="tm-value" id="caloriesFraction">– / –</span>
            </div>
            <div class="tm-bar-track" id="caloriesBar">
                <div class="tm-bar-fill" id="tm-calories-bar" style="background: var(--macro-calories); width:0%;"></div>
            </div>
        </div>

        <div class="tm-row">
            <div class="tm-row-header">
                <span class="tm-label" style="color: var(--macro-protein);">Protein</span>
                <span class="tm-value" id="proteinFraction">– / –</span>
            </div>
            <div class="tm-bar-track" id="proteinBar">
                <div class="tm-bar-fill" id="tm-protein-bar" style="background: var(--macro-protein); width:0%;"></div>
            </div>
        </div>

        <div class="tm-row">
            <div class="tm-row-header">
                <span class="tm-label" style="color: var(--macro-fats);">Fats</span>
                <span class="tm-value" id="fatFraction">– / –</span>
            </div>
            <div class="tm-bar-track" id="fatBar">
                <div class="tm-bar-fill" id="tm-fat-bar" style="background: var(--macro-fats); width:0%;"></div>
            </div>
        </div>

        <div class="tm-row">
            <div class="tm-row-header">
                <span class="tm-label" style="color: var(--macro-carbs);">Carbs</span>
                <span class="tm-value" id="carbsFraction">– / –</span>
            </div>
            <div class="tm-bar-track" id="carbsBar">
                <div class="tm-bar-fill" id="tm-carbs-bar" style="background: var(--macro-carbs); width:0%;"></div>
            </div>
        </div>
    </div>

</div>

<!-- Day Chip Row (weekly only) -->
<div class="day-chips-row" id="day-chips-row"></div>

<!-- Insight Cards -->
<div class="insight-grid">
    @foreach (var n in new[] { 1, 2 })
    {
        <div class="insight-card">
            <p id="insight-@n">–</p>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        window.nutritionData = {
            allDays:      @Html.Raw(allDaysJson),
            dailyTargets: @Html.Raw(targetsJson),
            initialTab:   '@Model.ActiveTab'
        };
    </script>
    <script src="~/js/nutritionSummary.js" asp-append-version="true"></script>
}
