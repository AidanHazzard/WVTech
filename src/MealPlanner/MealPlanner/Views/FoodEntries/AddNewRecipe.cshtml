@model MealPlanner.ViewModels.RecipeViewModel

<link rel="stylesheet" href="~/css/AddNewRecipe.css" asp-append-version="true" />

<div class="back1 backHasButton">
    <h1 class="back1Title">Create a Recipe</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        @Html.ValidationSummary(false, null, new { @class = "alert alert-danger" })
    }

    <form asp-controller="FoodEntries" asp-action="RecipeAdded" method="post" enctype="multipart/form-data">
        <h2 class="back1Title left">
            <span>Name:</span>
            <input class="back2-textbox" type="text" placeholder="Enter Recipe Name" asp-for="Name" required>
            </h2>


            <div class="back2 backHasButton" id="AppendHere"
                 data-measurements="@System.Text.Json.JsonSerializer.Serialize(Model.Measurements.Select(m => new { value = m.Name, label = m.Abbreviation }))">
                <h2 class="back1Title">Ingredients</h2>
                <button class="buttonGreen" id="buttonAppend">
                    <h2 class="buttonText">Add Ingredient</h2>
                </button>
            </div>

            <div class="back2">
                <h2 class="back1Title">Instructions</h2>
                <textarea class="back2-textbox instructionsBox" placeholder="Enter Instructions" asp-for="Directions" required></textarea>
            </div>

            <div class="back2">
                <h2 class="back1Title">Nutrients</h2>
                
                <h2 class="back1Title left">
                    <span>Calories:</span>
                    <input type="number" class="back2-textbox" placeholder="Enter Calories" min="0" max="32767" step="1" name="Calories" id="Calories" required>
                </h2>

                <h2 class="back1Title left">
                    <span>Protein:</span>
                    <input type="number" class="back2-textbox" placeholder="Enter Protein" min="0" max="32767" step="1" name="Protein" id="Protein" required>
                </h2>

                <h2 class="back1Title left">
                    <span>Carbs:</span>
                    <input type="number" class="back2-textbox" placeholder="Enter Carbs" min="0" max="32767" step="1" name="Carbs" id="Carbs" required>
                </h2>

                <h2 class="back1Title left">
                    <span>Fat:</span>
                    <input type="number" class="back2-textbox" placeholder="Enter Fat" min="0" max="32767" step="1" name="Fat" id="Fat" required>
                </h2>
            </div>

            @await Html.PartialAsync("_TagSelector")

            <div class="back2">
                <h2 class="back1Title">Recipe Image</h2>
                <div class="file-input-wrapper back2-textbox">
                    <label for="imageFile" class="file-browse-btn buttonGreenInline">
                        <h4 class="buttonText">Browse</h4>
                    </label>
                    <span class="file-name-display">No file chosen</span>
                    <input type="file" id="imageFile" name="ImageFile" accept="image/*" style="display:none;" />
                    <button type="button" class="deleteButton file-remove-btn" id="removeImageBtn" style="display:none;">
                        <img src="/images/icons/delete.png" alt="remove" class="deleteImage">
                    </button>
                </div>
                <img id="imagePreview" src="" alt="Image preview" class="image-preview" />
            </div>

            <button class="buttonBlue" type="submit">
                <h2 class="buttonText">Add Recipe</h2>
            </button>
    </form>
</div>


@section Scripts {
    <script src="~/js/newrecipepage.js"></script>
}