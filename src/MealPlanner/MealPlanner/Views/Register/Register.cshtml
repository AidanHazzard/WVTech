@using MealPlanner.ViewModels
@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<!-- 
    Main container for the Register page.
    Ensures consistent styling and layout for all account-related pages.
-->
<div class="account-container">
    <div class="account-box">
        <h2 class="text-center mb-4">Register</h2>

        <!-- 
            Form for user registration.
            - Uses POST method for secure submission.
            - Includes anti-forgery token to prevent CSRF attacks.
        -->
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <!-- Display model-level validation errors (e.g., password mismatch, duplicate email) -->
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Name input field -->
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- Email input field -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- Password input field -->
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <!-- Confirm Password input field -->
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <!-- Submit button styled with Bootstrap classes for full-width and padding -->
            <Input type="submit" value="Register" class="btn btn-primary w-100 p-2" />

            <!-- Link to login page for users who already have an account -->
            <p class="text-center mt-2">
                Already have an account? <a asp-controller="Login" asp-action="Login" class="text-decoration-none">Login here</a>
            </p>

            <!-- Back link to navigate to the home page -->
            <div class="text-center">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
   @{
    <!-- Include client-side validation scripts partial for unobtrusive validation -->
    await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
   }
}