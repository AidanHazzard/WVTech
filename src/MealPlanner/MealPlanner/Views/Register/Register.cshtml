@using MealPlanner.ViewModels
@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">

        <!-- Logo -->
        <div class="auth-logo">
            <i class="ti ti-bowl-spoon"></i>
            <span>OneBite</span>
        </div>

        <!-- Heading -->
        <h1 class="auth-heading">Create your account</h1>
        <p class="auth-sub">Join OneBite and start planning your meals</p>

        <!-- Validation summary -->
        <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>

        <form asp-action="Register" method="post" novalidate>
            @Html.AntiForgeryToken()

            <!-- Name -->
            <div class="auth-field">
                <label class="auth-label" asp-for="Name">Name</label>
                <input asp-for="Name" class="auth-input" type="text"
                       placeholder="Your name" autocomplete="name" />
                <span asp-validation-for="Name" class="auth-field-error"></span>
            </div>

            <!-- Email -->
            <div class="auth-field">
                <label class="auth-label" asp-for="Email">Email</label>
                <input asp-for="Email" class="auth-input" type="email"
                       placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="auth-field-error"></span>
            </div>

            <!-- Password -->
            <div class="auth-field">
                <label class="auth-label" asp-for="Password">Password</label>
                <div class="auth-input-wrap">
                    <input asp-for="Password" class="auth-input" type="password"
                           placeholder="••••••••" autocomplete="new-password" id="Password" />
                    <button type="button" class="auth-eye-btn" id="togglePassword" tabindex="-1"
                            aria-label="Toggle password visibility">
                        <i class="ti ti-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="auth-field-error"></span>
            </div>

            <!-- Confirm Password -->
            <div class="auth-field">
                <label class="auth-label" asp-for="ConfirmPassword">Confirm Password</label>
                <div class="auth-input-wrap">
                    <input asp-for="ConfirmPassword" class="auth-input" type="password"
                           placeholder="••••••••" autocomplete="new-password" id="ConfirmPassword" />
                    <button type="button" class="auth-eye-btn" id="toggleConfirmPassword" tabindex="-1"
                            aria-label="Toggle confirm password visibility">
                        <i class="ti ti-eye" id="eyeIconConfirm"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="auth-field-error"></span>
            </div>

            <!-- Submit -->
            <button type="submit" class="auth-submit">Register</button>

        </form>

        <div class="auth-divider"></div>

        <!-- Login link -->
        <p class="auth-register">
            Already have an account?
            <a asp-controller="Login" asp-action="Login" class="auth-link">Login here</a>
        </p>

        <!-- Back link -->
        <div class="auth-back">
            <a asp-controller="Home" asp-action="Index" class="auth-back-link">
                <i class="ti ti-arrow-left"></i>
                Back
            </a>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml"); }
    <script>
        function wireToggle(inputId, btnId, iconId) {
            const input = document.getElementById(inputId);
            const btn   = document.getElementById(btnId);
            const icon  = document.getElementById(iconId);
            if (!input || !btn || !icon) return;
            btn.addEventListener('click', function () {
                const show = input.type === 'password';
                input.type = show ? 'text' : 'password';
                icon.className = show ? 'ti ti-eye-off' : 'ti ti-eye';
            });
        }
        wireToggle('Password', 'togglePassword', 'eyeIcon');
        wireToggle('ConfirmPassword', 'toggleConfirmPassword', 'eyeIconConfirm');
    </script>
}
