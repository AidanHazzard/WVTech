@using MealPlanner.ViewModels
@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<!-- 
    Main container for the Change Password page.
    Ensures consistent styling and positioning for all account-related pages.
-->
<div class ="account-container">
    <div class="account-box">
        <h2 class="text-center mb-4">Change Password</h2>

        <!-- 
            Form for changing the user's password.
            - Uses POST method for secure submission.
            - Anti-forgery token is included to prevent CSRF attacks.
        -->
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            
            <!-- Display model-level validation errors only (e.g., password mismatch) -->
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Email field is readonly because the user cannot change it here -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" readonly />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- New password input -->
            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <!-- Confirm password input to ensure user correctly typed new password -->
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <!-- Submit button styled with Bootstrap classes for full-width and padding -->
            <Input type="submit" value="Submit" class="btn btn-primary w-100 p-2" />

            <!-- Back link to navigate back to the VerifyEmail page, styled as a text link -->
            <div class="text-center mt-2">
                <a asp-controller="Account" asp-action="VerifyEmail" class="text-decoration-none mt-3">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
   @{
    <!-- Include client-side validation scripts partial for unobtrusive validation -->
    await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
   }
}