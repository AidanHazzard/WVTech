@using MealPlanner.ViewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">

        <!-- Logo -->
        <div class="auth-logo">
            <i class="ti ti-bowl-spoon"></i>
            <span>OneBite</span>
        </div>

        <!-- Heading -->
        <h1 class="auth-heading">Welcome back</h1>
        <p class="auth-sub">Sign in to your account</p>

        <!-- Validation summary -->
        <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>

        <form asp-action="Login" method="post" novalidate>
            @Html.AntiForgeryToken()

            <!-- Email -->
            <div class="auth-field">
                <label class="auth-label" asp-for="Email">Email</label>
                <input asp-for="Email" class="auth-input" type="email"
                       placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="auth-field-error"></span>
            </div>

            <!-- Password -->
            <div class="auth-field">
                <label class="auth-label" asp-for="Password">Password</label>
                <div class="auth-input-wrap">
                    <input asp-for="Password" class="auth-input" type="password"
                           placeholder="••••••••" autocomplete="current-password" id="Password" />
                    <button type="button" class="auth-eye-btn" id="togglePassword" tabindex="-1"
                            aria-label="Toggle password visibility">
                        <i class="ti ti-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="auth-field-error"></span>
            </div>

            <!-- Remember me + Forgot password -->
            <div class="auth-remember-row">
                <label class="auth-checkbox-label">
                    <input asp-for="RememberMe" type="checkbox" class="auth-checkbox" />
                    <span class="auth-checkbox-box"></span>
                    <span class="auth-checkbox-text">Remember me</span>
                </label>
                <a asp-controller="Register" asp-action="VerifyEmail" class="auth-forgot">
                    Forgot your password?
                </a>
            </div>

            <!-- Submit -->
            <button type="submit" class="auth-submit">Sign in</button>

        </form>

        <div class="auth-divider"></div>

        <!-- Register link -->
        <p class="auth-register">
            Don't have an account?
            <a asp-controller="Register" asp-action="Register" class="auth-link">Register here</a>
        </p>

        <!-- Back link -->
        <div class="auth-back">
            <a asp-controller="Home" asp-action="Index" class="auth-back-link">
                <i class="ti ti-arrow-left"></i>
                Back
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        const pwd   = document.getElementById('Password');
        const btn   = document.getElementById('togglePassword');
        const icon  = document.getElementById('eyeIcon');
        if (btn && pwd && icon) {
            btn.addEventListener('click', function () {
                const show = pwd.type === 'password';
                pwd.type  = show ? 'text' : 'password';
                icon.className = show ? 'ti ti-eye-off' : 'ti ti-eye';
            });
        }
    </script>
}
