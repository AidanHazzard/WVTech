@using MealPlanner.ViewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<!-- 
    Main container for the Login / Landing page.
    This now serves as the public-facing landing page for unauthenticated users.
    Provides consistent styling and layout for account-related pages.
-->
<div class="account-container">
    <div class="account-box">

        <!-- Page Title -->
        <h2 class="text-center mb-2">Welcome to MealPlanner</h2>

        <!-- 
            Brief description of the application.
            This satisfies the requirement that the landing page includes 
            basic information about the application.
        -->
        <p class="text-center text-muted mb-4">
            Plan meals, manage dietary restrictions, and track your nutrition goals —
            all in one organized and easy-to-use platform.
        </p>

        <!-- 
            Form for user login.
            - Uses POST method for secure submission.
            - Anti-forgery token is included to prevent CSRF attacks.
        -->
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <!-- Display model-level validation errors (e.g., invalid credentials) -->
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Email input field -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- Password input field -->
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <!-- Forgot password link, floated to the right -->
            <div class="float-end">
                <a asp-controller="Register" asp-action="VerifyEmail" class="text-decoration-none">
                    Forgot your password?
                </a>
            </div>

            <!-- Remember Me checkbox -->
            <div class="mb-3 form-check">
                <label class="form-check-label">
                    <input asp-for="RememberMe" class="form-check-input" />
                    @Html.DisplayNameFor(m => m.RememberMe)
                </label>
            </div>

            <!-- Submit button styled with Bootstrap classes for full-width and padding -->
            <input type="submit" value="Login" class="btn btn-primary w-100 p-2" />

            <!-- 
                Link to register page for users without an account.
                This supports new user onboarding from the landing page.
            -->
            <p class="text-center mt-3">
                Don't have an account?
                <a asp-controller="Register" asp-action="Register" class="text-decoration-none">
                    Register here
                </a>
            </p>

        </form>
    </div>
</div>

@section Scripts {
   @{
       <!-- Include client-side validation scripts for unobtrusive validation -->
       await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
   }
}