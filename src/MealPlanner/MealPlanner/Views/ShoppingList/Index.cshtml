@model IEnumerable<MealPlanner.Models.ShoppingListItem>

@{
    ViewData["Title"] = "Shopping List";
}

<div class="container mt-4">
    <div class="p-4 rounded-4" style="background-color: #d9d9d9;">
        <h2 class="text-center mb-4">Shopping List</h2>

        @if (TempData["ShoppingListError"] != null)
        {
            <div class="alert alert-danger text-center">
                @TempData["ShoppingListError"]
            </div>
        }

        <form asp-action="AddItem" method="post" class="mb-4">
            @Html.AntiForgeryToken()

            <div class="d-flex gap-3 align-items-center">
                <input type="text"
                       name="itemName"
                       class="form-control rounded-4"
                       placeholder="Enter grocery item" />
                <button type="submit" class="btn btn-success px-4 rounded-4">Add Item</button>
            </div>
        </form>

        <div class="p-4 rounded-4" style="background-color: #efefef;">
            @if (Model.Any())
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var item in Model)
                    {
                        <div class="d-flex justify-content-between align-items-center p-3 rounded-4 bg-white">
                            <span class="fs-5">@item.Name</span>

                            <form asp-action="RemoveItem" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <button type="submit" class="btn btn-danger rounded-4 px-4">Remove</button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-center fs-5 mb-0">No items in your shopping list yet.</p>
            }
        </div>
    </div>
</div>