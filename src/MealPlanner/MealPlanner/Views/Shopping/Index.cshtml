@model MealPlanner.ViewModels.ShoppingListViewModel

@{
    ViewData["Title"] = "Shopping List";
}

<link rel="stylesheet" href="~/css/ShoppingList.css" asp-append-version="true" />

<div class="back1">
    <h1 class="back1Title">Shopping List</h1>

    @if (TempData["ShoppingListSuccess"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["ShoppingListSuccess"]
        </div>
    }

    @if (TempData["ShoppingListError"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["ShoppingListError"]
        </div>
    }

    @if (TempData["KrogerError"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["KrogerError"]
        </div>
    }

    @if (TempData["KrogerInfo"] != null)
    {
        <div class="alert alert-info text-center">
            @TempData["KrogerInfo"]
        </div>
    }

    <form asp-action="SetDateRange" method="post" class="mb-4" id="dateRangeForm">
        @Html.AntiForgeryToken()
        <div class="d-flex gap-3 align-items-center flex-wrap">
            <input type="date" name="dateFrom" value="@Model.DateFrom.ToString("yyyy-MM-dd")" class="back2-textbox date-range-input" />
            <span>to</span>
            <input type="date" name="dateTo" value="@Model.DateTo.ToString("yyyy-MM-dd")" class="back2-textbox date-range-input" />
        </div>
    </form>

    <form asp-action="AddItem" method="post" class="mb-4">
        @Html.AntiForgeryToken()
        <div class="d-flex align-items-center flex-wrap gap-1">
            <input type="text" class="back2-textbox-partial shopping-add-amount" name="amount" placeholder="e.g. 1/2" required />
            <select class="back2-textbox-partial shopping-add-unit" name="measurement" required>
                <option value="" selected disabled>Select</option>
                @foreach (var m in Model.Measurements)
                {
                    <option value="@m.Name">@m.Abbreviation</option>
                }
            </select>
            <input type="text" class="back2-textbox-partial shopping-add-name" name="itemName" placeholder="Enter Ingredient" required />
            <button type="submit" class="buttonGreenInline flex-shrink-0">
                <h4 class="buttonText">Add Item</h4>
            </button>
        </div>
    </form>

    <div class="back2">
        @if (TempData["KrogerSuccess"] != null)
        {
            <p class="text-center fs-5 mb-2">@TempData["KrogerSuccess"]</p>
        }

        <div id="shopping-items-container">
            @await Html.PartialAsync("_ShoppingListItems", Model)
        </div>

        <hr class="kroger-divider" />

        <div class="kroger-section-header">
            <h2 class="back1Title mb-0">Export to Kroger</h2>
            @if (Model.KrogerConnected)
            {
                <span class="kroger-connected-badge">&#10003; Connected</span>
            }
            <button type="button" id="previousExportsBtn" class="buttonBlueInline kroger-header-btn">
                <h4 class="buttonText">Previous Exports</h4>
            </button>
        </div>

        @if (!Model.Items.Any())
        {
            <p class="back1Title">Add items to your shopping list to export to Kroger.</p>
        }
        else
        {
            <div class="kroger-card">
                <p class="kroger-card-label">Find a Store</p>
                <div class="kroger-find-row">
                    <input type="text"
                           id="ZipCode"
                           value="@Model.ZipCode"
                           placeholder="Enter zip code"
                           maxlength="10"
                           class="back2-textbox kroger-zip-input" />
                    <button type="button" id="findKrogerStores" class="buttonBlueInline kroger-header-btn">
                        <h4 class="buttonText">Find Stores</h4>
                    </button>
                </div>
                <div class="radius-slider-row">
                    <span class="kroger-field-label">Radius</span>
                    <input type="range" id="radiusSlider" min="1" max="50" value="50" class="radius-slider" />
                    <span class="kroger-radius-badge" id="radiusLabel">50 mi</span>
                </div>

                <div id="krogerStoreSection" class="kroger-store-panel" style="display:none;">
                    <hr class="kroger-inner-divider" />
                    <p id="krogerStoreMessage" class="kroger-store-message" style="display:none;"></p>
                    <form asp-controller="Kroger" asp-action="Export" method="post" id="krogerExportForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="zipCodeHidden" name="zipCode" />
                        <select id="krogerStoreSelect" name="storeId" class="back2-textbox-partial kroger-store-select"></select>
                        <div class="kroger-export-row">
                            <button type="submit" id="exportToKroger" class="buttonBlueInline">
                                <h4 class="buttonText">Export to Kroger Cart</h4>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }

    </div>
</div>

<!-- Export History Modal -->
<div id="exportHistoryModal" class="export-modal-overlay">
    <div class="export-modal-panel back1 p-4 rounded-4">
        <div class="export-modal-header d-flex justify-content-between align-items-center mb-3">
            <h5 class="back1Title mb-0">Previous Exports</h5>
            <button type="button" id="closeExportHistory" class="btn btn-sm rounded-4 px-3 export-grey-btn">&#10005;</button>
        </div>
        <div id="exportHistoryBody" class="export-modal-body">
            <p class="text-center text-muted fst-italic">Loading...</p>
        </div>
    </div>
</div>

<!-- Templates for export history (cloned by krogerHistory.js) -->
<template id="tmpl-export-entry">
    <div class="export-history-entry back2 p-3 mb-2 rounded-4">
        <div class="d-flex justify-content-between align-items-center">
            <span class="fw-semibold fs-6 js-entry-label"></span>
            <span class="export-history-time js-entry-time"></span>
            <span class="export-history-chevron ms-2">&#9660;</span>
        </div>
        <div class="export-item-list mt-2"></div>
    </div>
</template>

<template id="tmpl-export-controls">
    <div class="d-flex gap-2 mb-1">
        <button type="button" class="btn btn-sm rounded-4 px-2 select-all-btn export-grey-btn export-ctrl-btn">Select All</button>
        <button type="button" class="btn btn-sm rounded-4 px-2 deselect-all-btn export-grey-btn export-ctrl-btn">Deselect All</button>
    </div>
</template>

<template id="tmpl-export-item">
    <div class="d-flex align-items-center gap-2 py-1 export-item-row">
        <input type="checkbox" class="form-check-input re-export-checkbox export-item-checkbox mt-0 flex-shrink-0" checked />
        <span class="flex-grow-1 js-item-label"></span>
    </div>
</template>

<template id="tmpl-export-footer">
    <div class="d-flex align-items-center gap-2 mt-2">
        <button class="btn btn-sm rounded-4 px-3 add-to-list-btn export-grey-btn">Add to Shopping List</button>
        <span class="add-to-list-status export-status-text"></span>
    </div>
</template>

<template id="tmpl-store-option">
    <option></option>
</template>

<datalist id="measurement-options">
    @foreach (var m in Model.Measurements)
    {
        <option value="@m.Abbreviation"></option>
    }
</datalist>

<script>
    window.krogerLastStoreId = '@Model.LastStoreId';
</script>
<script src="~/js/shoppingList.js"></script>
<script src="~/js/krogerHistory.js"></script>
