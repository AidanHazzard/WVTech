@model List<MealPlanner.Models.Ingredient>
@using MealPlanner.ViewModels

@{
    ViewData["Title"] = "My Pantry";
}

<link rel="stylesheet" href="~/css/shopping-shared.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/pantry.css" asp-append-version="true" />

<a href="/" class="page-back-link">
    <i class="ti ti-arrow-left"></i>
    Back
</a>

<div class="pantry-page">

    <!-- Header -->
    <div class="pantry-header">
        <span class="pantry-header-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 8H2"/>
                <path d="M2 8v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8"/>
                <path d="M22 8l-2-4H4L2 8"/>
                <path d="M12 12v4"/>
                <path d="M10 14h4"/>
            </svg>
        </span>
        <h1 class="pantry-title">My Pantry</h1>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="pantry-alert pantry-alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ValidationError"] != null)
    {
        <div class="pantry-alert pantry-alert-error">@TempData["ValidationError"]</div>
    }

    <!-- Add item card -->
    <div class="pantry-card">
        <form asp-action="AddPantryItem" method="post" class="pantry-add-form">
            @Html.AntiForgeryToken()
            <input id="Amount" name="Amount" type="number" step="any" min="0"
                   class="pantry-input pantry-qty-field" placeholder="0" />
            <select id="Measurement" name="Measurement" class="pantry-input pantry-unit-select">
                <option value="">Unit</option>
                <option value="Count">Count</option>
                <option value="Cup(s)">Cup(s)</option>
                <option value="Ounce(s)">Ounce(s)</option>
                <option value="Pound(s)">Pounds</option>
                <option value="L">L</option>
                <option value="KG">KG</option>
            </select>
            <input id="Name" name="Name" type="text"
                   class="pantry-input pantry-name-field" placeholder="Ingredient name" />
            <button id="addPantryItemBtn" type="submit" class="pantry-add-btn">Add to Pantry</button>
        </form>
    </div>

    <!-- Items list card -->
    <div class="pantry-card">
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="pantry-item-row">
                    <span class="pantry-item-name">@item.IngredientBase.Display()</span>
                    <div class="pantry-item-right">
                        <form asp-action="UpdatePantryItemAmount" method="post" class="pantry-qty-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ingredientId" value="@item.Id" />
                            <input type="number"
                                   name="newAmount"
                                   value="@item.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                   min="0.01"
                                   step="any"
                                   class="pantry-qty-pill-input pantry-qty-input"
                                   data-original="@item.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                   oninput="togglePantryQtySave(this)" />
                            <span class="pantry-qty-unit">@item.Measurement?.Name</span>
                            <button type="submit" class="pantry-qty-save-btn pantry-qty-save" style="display:none">Save</button>
                        </form>
                        <form asp-action="RemovePantryItem" method="post" class="pantry-remove-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ingredientId" value="@item.Id" />
                            <button type="submit" class="pantry-remove-btn" title="Remove item">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2.5"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18"/>
                                    <line x1="6" y1="6" x2="18" y2="18"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="pantry-empty">
                <svg class="pantry-empty-icon" xmlns="http://www.w3.org/2000/svg"
                     width="40" height="40" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="1.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 8H2"/>
                    <path d="M2 8v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8"/>
                    <path d="M22 8l-2-4H4L2 8"/>
                    <path d="M12 12v4"/>
                    <path d="M10 14h4"/>
                </svg>
                <p class="pantry-empty-text">Your pantry is empty. Add an item above.</p>
            </div>
        }
    </div>

</div>

<script>
    function togglePantryQtySave(input) {
        const btn = input.closest('form').querySelector('.pantry-qty-save');
        btn.style.display = parseFloat(input.value) !== parseFloat(input.dataset.original) ? 'inline-block' : 'none';
    }
    document.addEventListener('DOMContentLoaded', function () {
        document.getElementById('cartDropdown')?.classList.remove('open');
    });
    window.addEventListener('pageshow', function () {
        document.getElementById('cartDropdown')?.classList.remove('open');
    });
</script>
