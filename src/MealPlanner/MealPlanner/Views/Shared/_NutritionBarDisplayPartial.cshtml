@model NutritionBarInfoViewModel
<div>
    <div class="nutrition-bar-row">
        <span class="nutrition-bar-label" style="color: var(--macro-calories);">Calories:</span>
        <div id="caloriesBar" class="progress nutrition-bar-progress">
            <div class="progress-bar" role="progressbar"
                aria-valuenow="@Model.CaloriesCurrent"
                aria-valuemin="0"
                aria-valuemax="@Model.CaloriesMax"
                style="width: @Model.CaloriesAverage%; background-color: @(Model.CaloriesCurrent > Model.CaloriesMax ? "#FF0000" : "var(--macro-calories)");">
            </div>
        </div>
        <span id="caloriesFraction" class="nutrition-bar-fraction">
            @Model.CaloriesCurrent / @Model.CaloriesMax
        </span>
    </div>
    <div class="nutrition-bar-row">
        <span class="nutrition-bar-label" style="color: var(--macro-protein);">Protein:</span>
        <div id="proteinBar" class="progress nutrition-bar-progress">
            <div class="progress-bar" role="progressbar"
                aria-valuenow="@Model.ProteinCurrent"
                aria-valuemin="0"
                aria-valuemax="@Model.ProteinMax"
                style="width: @Model.ProteinAverage%; background-color: @(Model.ProteinCurrent > Model.ProteinMax ? "#FF0000" : "var(--macro-protein)");">
            </div>
        </div>
        <span id="proteinFraction" class="nutrition-bar-fraction">
            @Model.ProteinCurrent / @Model.ProteinMax
        </span>
    </div>
    <div class="nutrition-bar-row">
        <span class="nutrition-bar-label" style="color: var(--macro-fats);">Fats:</span>
        <div id="fatBar" class="progress nutrition-bar-progress">
            <div class="progress-bar" role="progressbar"
                aria-valuenow="@Model.FatsCurrent"
                aria-valuemin="0"
                aria-valuemax="@Model.FatsMax"
                style="width: @Model.FatsAverage%; background-color: @(Model.FatsCurrent > Model.FatsMax ? "#FF0000" : "var(--macro-fats)");">
            </div>
        </div>
        <span id="fatFraction" class="nutrition-bar-fraction">
            @Model.FatsCurrent / @Model.FatsMax
        </span>
    </div>
    <div class="nutrition-bar-row">
        <span class="nutrition-bar-label" style="color: var(--macro-carbs);">Carbs:</span>
        <div id="carbsBar" class="progress nutrition-bar-progress">
            <div class="progress-bar" role="progressbar"
                aria-valuenow="@Model.CarbsCurrent"
                aria-valuemin="0"
                aria-valuemax="@Model.CarbsMax"
                style="width: @Model.CarbsAverage%; background-color: @(Model.CarbsCurrent > Model.CarbsMax ? "#FF0000" : "var(--macro-carbs)");">
            </div>
        </div>
        <span id="carbsFraction" class="nutrition-bar-fraction">
            @Model.CarbsCurrent / @Model.CarbsMax
        </span>
    </div>
</div>