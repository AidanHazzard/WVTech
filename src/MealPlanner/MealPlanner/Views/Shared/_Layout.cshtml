@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    var isAuthed = User?.Identity?.IsAuthenticated == true;
    var theme = Context.Items["Theme"]?.ToString() ?? "light";

    var isHome    = currentController == "Home" && currentAction == "Index";
    var isRecipes = currentController == "FoodEntries" && currentAction != "NutritionSummary";
    var isReport  = currentController == "FoodEntries" && currentAction == "NutritionSummary";
    var isCart    = currentController == "Shopping";

    string initials = "";
    if (isAuthed)
    {
        var navInitialsOverride = Context.Items["NavInitials"]?.ToString() ?? "";
        if (!string.IsNullOrEmpty(navInitialsOverride))
        {
            initials = navInitialsOverride;
        }
        else
        {
            var name  = User.Identity?.Name ?? "";
            var local = name.Contains('@') ? name.Split('@')[0] : name;
            initials  = local.Length >= 2
                ? $"{char.ToUpper(local[0])}{char.ToUpper(local[1])}"
                : local.ToUpper();
        }
    }

    var navPhotoUrl = Context.Items["ProfilePictureUrl"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="en" data-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OneBite</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/dist/tabler-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MealPlanner.styles.css" asp-append-version="true" />
</head>

<body>
<header>
    <nav class="top-nav">
        <a class="top-nav-logo" href="/">
            <i class="ti ti-bowl-spoon"></i>
            <span>OneBite</span>
        </a>

        <div class="top-nav-links">
            <a href="@Url.Action("Index", "Home")"
               class="top-nav-link @(isHome ? "active" : "")">Home</a>

            <a href="@Url.Action("Recipes", "FoodEntries", new { id = (int?)null })"
               class="top-nav-link @(isRecipes ? "active" : "")">Recipes</a>

            <a href="@Url.Action("NutritionSummary", "FoodEntries")"
               class="top-nav-link @(isReport ? "active" : "")">Summary</a>

            <div class="top-nav-dropdown" id="cartDropdown">
                <button type="button"
                        class="top-nav-link top-nav-dropdown-btn @(isCart ? "active" : "")">
                    MyCart
                    <svg class="top-nav-chevron" xmlns="http://www.w3.org/2000/svg"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="top-nav-dropdown-menu">
                    <a href="@Url.Action("Index", "Shopping")">Shopping List</a>
                    <a href="@Url.Action("Pantry", "Shopping")">Pantry</a>
                </div>
            </div>
        </div>

        @if (isAuthed)
        {
            <a href="@Url.Action("Index", "UserSettings")" class="top-nav-avatar @(!string.IsNullOrEmpty(navPhotoUrl) ? "has-photo" : "")" id="navAvatar">
                <span id="navAvatarInitials">@initials</span>
                <img id="navAvatarPhoto" src="@navPhotoUrl" alt=""
                     style="@(string.IsNullOrEmpty(navPhotoUrl) ? "display:none" : "")"
                     onerror="this.style.display='none'; var el=document.getElementById('navAvatarInitials'); if(el) el.style.display=''; var av=document.getElementById('navAvatar'); if(av) av.classList.remove('has-photo');" />
            </a>
        }
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<!-- Global delete confirmation modal -->
<div id="deleteConfirmModal" class="dcm-backdrop" style="display:none" aria-modal="true" role="dialog">
    <div class="dcm-panel">
        <div class="dcm-icon-wrap">
            <i class="ti ti-trash dcm-icon"></i>
        </div>
        <p class="dcm-title" id="dcmTitle">Delete this item?</p>
        <p class="dcm-sub">This action cannot be undone. The item will be permanently removed.</p>
        <div class="dcm-btn-row">
            <button type="button" class="dcm-btn dcm-btn--cancel inline-confirm-no" id="dcmCancel">Cancel</button>
            <button type="button" class="dcm-btn dcm-btn--delete inline-confirm-yes" id="dcmConfirm">Delete</button>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" type="module" asp-append-version="true"></script>
<script src="~/js/deleteModal.js" asp-append-version="true"></script>
<script src="~/js/inlineConfirm.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
