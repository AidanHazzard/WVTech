@model MealPlanner.ViewModels.PlannerHomeViewModel

<div class="back1">

    <div class="back2">
        <h2 class="text-center">Meal Plan</h2>
    </div>

    <div class="back2 mt-3 p-3">
        <form method="get" asp-action="PlannerHome" class="row align-items-end g-3">
            <div class="col-md-4">
                <label class="form-label">Select Date</label>
                <input type="date"
                       name="date"
                       value="@Model.SelectedDate.ToString("yyyy-MM-dd")"
                       class="form-control" />
            </div>

            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">View</button>
            </div>
        </form>
    </div>

    <div class="back2 mt-3 p-3">
        @if (Model.Meals == null || !Model.Meals.Any())
        {
            <h4 class="text-center">No meals scheduled for this day.</h4>
        }
        else
        {
            <div class="list-group">
                @foreach (var meal in Model.Meals)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-bold d-flex align-items-center gap-2">
                                    <form asp-action="ToggleMealCompleted" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@meal.Id" />
                                        <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                                        <input type="checkbox"
                                               name="isCompleted"
                                               value="true"
                                               @(meal.IsCompleted ? "checked" : null)
                                               onchange="this.form.submit()" />
                                    </form>

                                    <span>@meal.Title</span>

                                    @if (meal.RepeatRule == "Weekly")
                                    {
                                        <span class="badge bg-info ms-2">Weekly</span>
                                    }

                                    @if (meal.IsCompleted)
                                    {
                                        <span class="badge bg-success ms-2">Completed</span>
                                    }
                                </div>

                                <div class="mt-2">
                                    @if (meal.Recipes != null && meal.Recipes.Any())
                                    {
                                        foreach (var r in meal.Recipes)
                                        {
                                            <span class="badge bg-secondary me-1">@r.Name</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">No recipes attached</span>
                                    }
                                </div>
                            </div>

                            <form asp-action="DeleteMeal" method="post" class="ms-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@meal.Id" />
                                <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />

                                <button type="button"
                                        class="btn btn-danger btn-sm mealDeleteButton"
                                        data-testid="delete-meal"
                                        onclick="if (confirm('Are you sure you want to delete this meal?')) this.closest('form').submit();">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="row align-items-center mt-3">
        <div class="col d-flex justify-content-center">
            <form asp-action="NewMeal" method="get">
                <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                <button type="submit" class="imageButton">
                    <img src="~/images/icons/meal.png" alt="meal" class="imageButtonimage">
                    <div class="buttonBlue">
                        <h2 class="buttonText">Add a Meal</h2>
                    </div>
                </button>
            </form>
        </div>
    </div>

</div>