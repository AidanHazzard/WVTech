@model MealPlanner.ViewModels.SelectMealViewModel

<div class="back1 backHasButton">
    <h2 class="back1Title">Select A Meal</h2>

    <div id="selectMealList" class="d-flex flex-column gap-2">
        @if (Model == null || Model.Meals == null || Model.Meals.Count == 0)
        {
            <div class="back2">
                <h4 class="baseText">You have not created any meals yet.</h4>
            </div>
        }
        else
        {
            @foreach (var meal in Model.Meals)
            {
                <div class="back2 d-flex align-items-center gap-2 back2-textbox selectMealRow w-100">
                    <form asp-action="AddMealToDay" method="post" class="flex-grow-1 m-0 p-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="mealId" value="@meal.Id" />
                        <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                        <button type="submit"
                                class="w-100 text-start border-0 bg-transparent p-0"
                                style="cursor:pointer;"
                                data-meal-id="@meal.Id">
                            <h4 class="mb-0 selectMealName">@meal.Title</h4>
                        </button>
                    </form>
                    <form asp-action="RemoveMealTemplate" method="post" class="m-0 p-0 flex-shrink-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="mealId" value="@meal.Id" />
                        <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                        <button type="submit" class="mealDeleteButton mealRemoveButton" title="Remove meal">✕</button>
                    </form>
                </div>
            }
        }
    </div>

    <form asp-controller="Meal" asp-action="NewMeal" method="get">
        <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
        <button class="buttonBlue">
            <h2 class="buttonText">Add A Meal</h2>
        </button>
    </form>
</div>
