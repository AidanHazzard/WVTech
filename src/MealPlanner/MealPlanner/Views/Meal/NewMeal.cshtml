@model MealPlanner.ViewModels.CreateMealViewModel
@using MealPlanner.Models
@{
    DateTime today = DateTime.Today;
    var tags = (List<Tag>)(ViewBag.AvailableTags ?? new List<Tag>());
    var tagsJson = System.Text.Json.JsonSerializer.Serialize(
        tags.Select(t => new { id = t.Id, name = t.Name }));

    var displayMonth = Model.SelectedMonth > 0 ? Model.SelectedMonth : today.Month;
    var displayDay   = Model.SelectedDay   > 0 ? Model.SelectedDay   : today.Day;
    var displayDate  = new DateTime(today.Year, displayMonth, Math.Min(displayDay, DateTime.DaysInMonth(today.Year, displayMonth)));
}

<link rel="stylesheet" href="~/css/newMeal.css" asp-append-version="true" />

<!-- ── Day Plan Wizard Modal ── -->
<div class="modal fade" id="dayPlanModal" tabindex="-1" aria-labelledby="dayPlanModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered gdp-dialog">
        <div class="modal-content gdp-content">

            <button type="button" class="gdp-close" data-bs-dismiss="modal" aria-label="Close">
                <i class="ti ti-x"></i>
            </button>

            <div class="gdp-title-row">
                <span class="gdp-icon-box"><i class="ti ti-calendar-bolt"></i></span>
                <span class="gdp-title" id="dayPlanModalLabel">Generate day plan</span>
            </div>

            <form asp-action="GenerateDayPlan" method="POST" id="dayPlanForm" data-tags="@tagsJson">
                @Html.AntiForgeryToken()

                <input type="hidden" name="SelectedMonth" id="hiddenMonth" />
                <input type="hidden" name="SelectedDay" id="hiddenDay" />

                <div id="step1">
                    <div class="gdp-fields">

                        <div class="gdp-field">
                            <label class="gdp-label">Meal Date</label>
                            <div class="gdp-date-grid">
                                <select id="dayPlanMonth" class="gdp-input gdp-select">
                                    @for (int i = 1; i <= 12; i++)
                                    {
                                        <!option value="@i" @(i == Model.SelectedMonth ? "selected" : "")>
                                            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                                        </!option>
                                    }
                                </select>
                                <select id="dayPlanDay" class="gdp-input gdp-select">
                                    @for (int i = 1; i <= 31; i++)
                                    {
                                        <!option value="@i" @(i == Model.SelectedDay ? "selected" : "")>@i</!option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="gdp-field">
                            <label class="gdp-label" for="MealCount">Number of meals</label>
                            <input id="MealCount" name="MealCount" type="number"
                                   min="1" max="10" value="3" class="gdp-input" />
                        </div>

                    </div>

                    <button type="button" data-action="next-step" class="gdp-next-btn">
                        Next — Configure Meals
                        <i class="ti ti-arrow-right"></i>
                    </button>
                </div>

                <div id="step2" style="display:none">
                    <div class="gdp-progress-area">
                        <span id="mealStepLabel" class="gdp-step-label"></span>
                        <div id="gdpProgressBar" class="gdp-progress-bar"></div>
                    </div>
                    <div id="mealPreferenceSections"></div>
                    <div class="gdp-nav-row">
                        <button type="button" id="btnPrevMeal" class="gdp-back-btn" style="display:none">← Back</button>
                        <button type="button" id="btnNextMeal" class="gdp-nav-next-btn" style="display:none">
                            Next <i class="ti ti-arrow-right"></i>
                        </button>
                        <button type="submit" id="btnGeneratePlan" class="gdp-nav-next-btn" style="display:none">
                            Generate <i class="ti ti-sparkles"></i>
                        </button>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>

<!-- ── Recommend Meal Modal ── -->
<div class="modal fade" id="recommendMealModel">
    <div class="modal-dialog modal-dialog-centered rmo-dialog">
        <div class="modal-content rmo-content">

            <button type="button" class="rmo-close" data-bs-dismiss="modal" aria-label="Close">
                <i class="ti ti-x"></i>
            </button>

            <div class="rmo-title-row">
                <span class="rmo-icon-box"><i class="ti ti-sparkles"></i></span>
                <span class="rmo-title">Recommend a meal</span>
            </div>

            <form asp-action="GenerateMeal" method="POST" id="recommendMealForm" data-tags="@tagsJson">
                <div class="rmo-fields">

                    <div class="rmo-field">
                        <label class="rmo-label" for="recommendMealTitle">Meal Title</label>
                        <input asp-for="Title" id="recommendMealTitle" class="rmo-input" placeholder="Lunch" />
                    </div>

                    <div class="rmo-field">
                        <label class="rmo-label">Meal Date</label>
                        <div class="rmo-date-grid">
                            <select name="SelectedMonth" class="rmo-input rmo-select">
                                @for (int i = 1; i <= 12; i++)
                                {
                                    <!option @(i == Model.SelectedMonth ? "selected" : "") value="@i">
                                        @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                                    </!option>
                                }
                            </select>
                            <select name="SelectedDay" class="rmo-input rmo-select">
                                @for (int i = 1; i <= 31; i++)
                                {
                                    <!option value="@i" @(i == Model.SelectedDay ? "selected" : "")>@i</!option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="rmo-field">
                        <label class="rmo-label" for="recommendMealSize">Size</label>
                        <select name="Size" id="recommendMealSize" class="rmo-input rmo-select">
                            <option value="Small">Small</option>
                            <option value="Average" selected>Average</option>
                            <option value="Large">Large</option>
                        </select>
                    </div>

                    <div class="rmo-field">
                        <label class="rmo-label">Tags (optional)</label>
                        <div id="recommendMealTagPills" class="rmo-tag-pills"></div>
                        <div class="rmo-tag-add-row">
                            <select id="recommendMealTagSelect" class="rmo-input rmo-select rmo-tag-select">
                                <option value="">Select a tag...</option>
                                @foreach (var tag in tags)
                                {
                                    <option value="@tag.Id">@tag.Name</option>
                                }
                            </select>
                            <input type="text" id="recommendMealCustomTag" class="rmo-input rmo-tag-text" placeholder="Custom tag..." />
                            <button type="button" id="recommendMealAddTag" class="rmo-add-tag-btn">Add</button>
                        </div>
                    </div>

                </div>

                <button class="rmo-generate-btn" type="submit">
                    <i class="ti ti-sparkles"></i>
                    <span id="finishRecommendMeal">Generate Meal</span>
                </button>
            </form>

        </div>
    </div>
</div>

<!-- ── Page header ─────────────────────────────────────────────── -->
<div class="new-meal-header">
    <h1 class="new-meal-title">Add a meal</h1>
    <div class="new-meal-subdate">@today.ToString("MMMM d, yyyy")</div>
</div>

<!-- ── Segmented control ───────────────────────────────────────── -->
<div class="meal-seg-control">
    <button type="button" class="meal-seg-btn active" id="segSingle">Single meal</button>
    <button type="button" class="meal-seg-btn" id="showDayPlanWizard"
            data-bs-toggle="modal" data-bs-target="#dayPlanModal">Generate day plan</button>
</div>

<!-- ── Single meal pane ───────────────────────────────────────── -->
<form id="createMealForm" asp-action="NewMeal" method="post">

    <!-- AI recommendation banner -->
    <div class="ai-banner" id="recommendMeal" data-bs-toggle="modal" data-bs-target="#recommendMealModel" role="button" tabindex="0">
        <div class="ai-banner-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
        </div>
        <div class="ai-banner-body">
            <div class="ai-banner-title">OneBite Recommendation</div>
            <div class="ai-banner-sub">Let us suggest a meal based on your nutrition goals</div>
        </div>
        <div class="ai-banner-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </div>
    </div>

    <!-- Meal details card -->
    <div class="new-meal-card">
        <div class="new-meal-card-header">
            <div class="new-meal-card-header-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <span class="new-meal-card-header-title">Meal details</span>
        </div>
        <div class="new-meal-card-body">
            <div class="text-danger" asp-validation-summary="ModelOnly" style="font-size:12px"></div>

            <!-- 3-col form: title / month / day -->
            <div class="meal-form-grid">
                <div>
                    <label class="meal-label" asp-for="Title">Title</label>
                    <input asp-for="Title" class="meal-input mealInput" placeholder="e.g. Lunch" />
                    <span asp-validation-for="Title" class="text-danger" style="font-size:11px"></span>
                </div>
                <div>
                    <label class="meal-label" asp-for="SelectedMonth">Month</label>
                    <select asp-for="SelectedMonth" class="meal-input meal-select" id="SelectedMonth">
                        <option value="">Month</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            <!option @(i == Model.SelectedMonth ? "selected" : "") value="@i">
                                @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                            </!option>
                        }
                    </select>
                    <span asp-validation-for="SelectedMonth" class="text-danger" style="font-size:11px"></span>
                </div>
                <div>
                    <label class="meal-label" asp-for="SelectedDay">Day</label>
                    <select asp-for="SelectedDay" class="meal-input meal-select" id="SelectedDay">
                        <option value="">Day</option>
                        @for (int i = 1; i <= 31; i++)
                        {
                            <!option value="@i" @(i == Model.SelectedDay ? "selected" : "")>@i</!option>
                        }
                    </select>
                    <span asp-validation-for="SelectedDay" class="text-danger" style="font-size:11px"></span>
                </div>
            </div>

            <!-- Repeat weekly visual toggle -->
            <div class="repeat-toggle-row">
                <div class="toggle-switch" id="repeatToggleVisual" role="button" tabindex="0" aria-label="Toggle repeat weekly" style="position:relative; overflow:hidden;">
                    <input asp-for="RepeatWeekly" id="repeatWeeklyToggle" type="checkbox"
                           style="position:absolute; opacity:0; inset:0; width:100%; height:100%; cursor:pointer; margin:0;" />
                    <div class="toggle-knob"></div>
                </div>
                <span class="toggle-label" id="repeatToggleLabel">Repeat weekly</span>
            </div>

            <!-- Repeat day chips (visible when repeat weekly is on) -->
            <div id="repeatDaysPanel">
                <div class="repeat-days-row">
                    @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                    {
                        <label class="repeat-day-chip @(Model.RepeatDays.Contains(day) ? "on" : "")"
                               data-day="@((int)day)"
                               style="position:relative;">
                            <input type="checkbox"
                                   id="repeatDay_@day"
                                   name="RepeatDays"
                                   value="@((int)day)"
                                   class="repeat-day-checkbox"
                                   @(Model.RepeatDays.Contains(day) ? "checked" : "")
                                   style="position:absolute; width:1px; height:1px; overflow:hidden;" />
                            @day.ToString().Substring(0, 3)
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Selected recipes card (hidden until at least one recipe is chosen) -->
    <div class="new-meal-card nm-selected-card" id="selectedRecipesCard">
        <div class="new-meal-card-header">
            <div class="new-meal-card-header-icon">
                <i class="ti ti-bowl-chopsticks" style="font-size:13px"></i>
            </div>
            <span class="new-meal-card-header-title">Recipes in this meal</span>
        </div>
        <div class="new-meal-card-body nm-selected-body" id="createMealList"></div>
    </div>

    <!-- Recipe search card -->
    <div class="new-meal-card">
        <div class="new-meal-card-header">
            <div class="new-meal-card-header-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </div>
            <span class="new-meal-card-header-title">Add recipes</span>
        </div>
        <div class="new-meal-card-body">

            <!-- Search input with leading icon -->
            <div class="search-input-wrapper">
                <svg class="search-input-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input id="searchText" class="meal-input" type="text"
                       placeholder="Search recipes…" autocomplete="off" />
            </div>

            <!-- Tag filter chips — populated by createMeal.js / recipeSearch.js -->
            <div class="search-tag-chips" id="tagFilterChips"></div>
            <select id="tagFilter" style="display:none"><option value="">All</option></select>

            <div id="error" style="font-size:13px; color:var(--muted-text); text-align:center; min-height:0"></div>

            <!-- Recipe results (populated by recipeSearch.js) -->
            <div id="recipeResults"></div>

            <button type="button" id="addSelectedRecipesBtn" class="nm-add-selected-btn" style="display:none">
                Add selected
            </button>

            <!-- Recipe result template -->
            <template id="recipeResult">
                <div class="recipeSearchRow" externaluri="">
                    <img class="recipe-thumbnail" src="" alt="" />
                    <div class="recipe-row-info">
                        <div class="recipeName"></div>
                        <div class="recipeTags"></div>
                        <div hidden class="recipeId"></div>
                        <input type="hidden" class="recipeIdInput" value="" />
                        <div class="recipeRating"></div>
                    </div>
                    <div class="recipe-select-check">
                        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="3"
                             stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </div>
                </div>
            </template>

            <img src="~/images/icons/Edamam_Badge.svg" class="edamam-badge" width="200" height="100" />
        </div>
    </div>

    <!-- Action bar -->
    <div class="meal-action-bar">
        <a href="@Url.Action("Index", "Home")" class="meal-action-cancel">Cancel</a>
        <button type="submit" class="meal-action-submit" id="createMeal" form="createMealForm">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span id="addMealBtnLabel">Add meal to @displayDate.ToString("MMM d")</span>
        </button>
    </div>

</form>

<!-- Tag selector template for generateDayPlan.js -->
<template id="mealTagTemplate">
    <div class="tags-container gdp-tag-pills"></div>
    <div class="gdp-tag-add-row">
        <select class="tag-select gdp-input gdp-select gdp-tag-select">
            <option value="">Select a tag...</option>
        </select>
        <input type="text" class="custom-tag-input gdp-input gdp-tag-text" placeholder="Custom tag..." />
        <button type="button" class="add-tag-btn gdp-add-tag-btn">Add</button>
    </div>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module" src="~/js/recipeSearch.js"></script>
    <script type="module" src="~/js/createMeal.js"></script>
    <script src="~/js/generateDayPlan.js"></script>
    <script src="~/js/newMeal.js" asp-append-version="true"></script>
}
