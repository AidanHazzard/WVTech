@model MealPlanner.ViewModels.CreateMealViewModel
@using MealPlanner.Models
@{
    DateTime today = DateTime.Today;
    var tags = (List<Tag>)(ViewBag.AvailableTags ?? new List<Tag>());
    var tagsJson = System.Text.Json.JsonSerializer.Serialize(
        tags.Select(t => new { id = t.Id, name = t.Name }));
}

<div class="back1 backHasButton">
    <h2 class="back1Title">Recommend Meal</h2>
    <div class="buttonRow">
        <button class="buttonBlueInline">
            <h4 id="recommendMeal" class="buttonText" data-bs-toggle="modal" data-bs-target="#recommendMealModel">Recommend Meal</h4>
        </button>
        <button id="showDayPlanWizard" class="buttonBlueInline" type="button"
                data-bs-toggle="modal" data-bs-target="#dayPlanModal">
            <h4 class="buttonText">Generate Day Plan</h4>
        </button>
    </div>
</div>

<!-- Day Plan Wizard Modal -->
<div class="modal fade" id="dayPlanModal" tabindex="-1" aria-labelledby="dayPlanModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content back1 backHasButton">
            <div class="modal-header border-0 pb-0">
                <h2 class="back1Title modal-title" id="dayPlanModalLabel">Generate Day Plan</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2">
                <form asp-action="GenerateDayPlan" method="POST" id="dayPlanForm" data-tags="@tagsJson">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="SelectedMonth" id="hiddenMonth" />
                    <input type="hidden" name="SelectedDay" id="hiddenDay" />

                    <!-- Step 1: meal count -->
                    <div id="step1">
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label for="MealCount" class="form-label">How many meals would you like today?</label>
                                <input id="MealCount" name="MealCount" type="number"
                                       min="1" max="10" value="3" class="form-control" />
                            </div>
                        </div>

                        <button type="button" data-action="next-step" class="buttonBlue mt-2">
                            <h4 class="buttonText">Next — Configure Meals</h4>
                        </button>
                    </div>

                    <!-- Step 2: per-meal configuration (populated by JS) -->
                    <div id="step2" style="display:none">
                        <p id="mealStepLabel" class="text-muted mb-2"></p>
                        <div id="mealPreferenceSections"></div>

                        <div class="d-flex gap-2 mt-3">
                            <button type="button" id="btnPrevMeal" class="btn btn-secondary" style="display:none">← Back</button>
                            <button type="button" id="btnNextMeal" class="btn btn-primary" style="display:none">Next →</button>
                            <button type="submit" id="btnGeneratePlan" class="buttonBlue" style="display:none">
                                <h4 class="buttonText">Generate Day Plan</h4>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="recommendMealModel">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content back1 backHasButton">
            <h1 class="back1Title">Recommend Meal</h1>
            <hr />
            <form asp-action="GenerateMeal" method="POST">
                <label for="recommendMealTitle">Meal Title</label>
                <input asp-for="Title" id="recommendMealTitle" class="back2-textbox" placeholder="Lunch"/>

                <label>Meal Date</label>
                <select name="SelectedMonth" class="back2-textbox">
                    @for (int i = 1; i <= 12; i++)
                    {
                        <!option @(i==today.Month ? "selected" : "") value="@i">
                            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                        </!option>
                    }
                </select>
                <select name="SelectedDay" class="back2-textbox">
                    @for (int i = 1; i <= 31; i++)
                    {
                        <!option value="@i" @(i==today.Day ? "selected" : "")>@i</!option>
                    }
                </select>

                <button class="buttonBlue" type="submit">
                    <h4 id="finishRecommendMeal" class="buttonText">Generate Meal</h4>
                </button>
            </form>
        </div>
    </div>
</div>

<div class="back1 backHasButton">
    <h2 class="back1Title">Create a Meal</h2>
    <hr>

    <div id="createMealList">
        <template id="addRecipeRow">
            <div class="back2 d-flex align-items-center gap-2 back2-textbox mealRecipeItem">
                <h4 id="recipeName" class="mb-0 flex-grow-1">{Recipe Name}</h4>
                <input type="hidden" name="RecipeIds" class="recipeIdInput" />
                <button type="button" class="btn btn-danger delete-recipe-btn">X</button>
            </div>
        </template>
    </div>

    <div class="row align-items-center">
        <div class="text-danger" asp-validation-summary="All"></div>

        <form id="createMealForm" class="col d-flex flex-column mx-1" asp-action="NewMeal" method="post">

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control mealInput" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="SelectedMonth" class="form-label">Month</label>
                    <select asp-for="SelectedMonth" class="form-control mealSelect">
                        <option value="">Select month</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            <!option @(i==today.Month ? "selected" : "") value="@i">
                                @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                            </!option>
                        }
                    </select>
                    <span asp-validation-for="SelectedMonth" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="SelectedDay" class="form-label">Day</label>
                    <select asp-for="SelectedDay" class="form-control mealSelect">
                        <option value="">Select day</option>
                        @for (int i = 1; i <= 31; i++)
                        {
                            <!option value="@i" @(i==today.Day ? "selected" : "")>@i</!option>
                        }
                    </select>
                    <span asp-validation-for="SelectedDay" class="text-danger"></span>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="RepeatWeekly" class="form-check-input" />
                        <label asp-for="RepeatWeekly" class="form-check-label">Repeat Weekly</label>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @await Html.PartialAsync("_RecipeSearchPartial")

    <button id="createMeal" type="submit" form="createMealForm" class="buttonBlue">
        <h4 class="buttonText">Create Meal</h4>
    </button>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module" src="~/js/recipeSearch.js"></script>
    <script type="module" src="~/js/createMeal.js"></script>
    <script src="~/js/generateDayPlan.js"></script>
}
