@model MealPlanner.ViewModels.DayPlanSummaryViewModel
@using MealPlanner.Models
@{
    ViewData["Title"] = "Day Plan Summary";
    var tagsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.AvailableTags.Select(t => new { id = t.Id, name = t.Name }));
}

<link rel="stylesheet" href="~/css/dayPlanSummary.css" asp-append-version="true" />

<a href="javascript:history.back()" class="page-back-link">
    <i class="ti ti-arrow-left"></i>
    Back
</a>

<div class="dps-page">

    <div class="dps-header">
        <h1 class="dps-title">Day Plan — @Model.Date.ToString("MMMM d")</h1>
    </div>

    <div id="day-plan-summary" data-tags="@tagsJson">
        @if (!Model.Meals.Any())
        {
            <p>No meals were generated. Please try again.</p>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                @foreach (var meal in Model.Meals)
                {
                    <div class="col">
                        <div id="meal-card-@meal.MealId" class="dps-card h-100">
                            <h4 class="dps-meal-title" data-meal-name data-meal-id="@meal.MealId">@meal.Title</h4>

                            <div data-recipe-list>
                                @if (meal.Recipes.Any())
                                {
                                    @foreach (var recipe in meal.Recipes)
                                    {
                                        <div class="mealRecipeItem dps-recipe-row"
                                             data-recipe-id="@recipe.Id"
                                             data-meal-id="@meal.MealId"
                                             data-recipe-url="@Url.Action("Recipes", "FoodEntries", new { id = recipe.Id })"
                                             style="cursor:pointer;">
                                            <h4 class="mb-0 flex-grow-1">@recipe.Name</h4>
                                            <div class="d-flex gap-2 align-items-center">
                                                <span class="ms-2 text-nowrap">@recipe.Calories cal</span>
                                                @if (meal.Recipes.Count > 1)
                                                {
                                                    <button type="button"
                                                            class="dps-refresh-btn"
                                                            data-action="regenerate-recipe"
                                                            data-recipe-id="@recipe.Id"
                                                            data-meal-id="@meal.MealId"
                                                            title="Regenerate this recipe">
                                                        <i class="ti ti-refresh"></i>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="text-muted mb-0">No recipes in this meal.</p>
                                }
                            </div>

                            <div id="regenerate-form-@meal.MealId" style="display:none" class="mt-3">
                                <form>
                                    @Html.AntiForgeryToken()

                                    <div class="d-flex flex-column gap-3 mb-3">
                                        <div>
                                            <label class="dps-form-label">Meal size</label>
                                            <select name="Size"
                                                    id="regen-@meal.MealId-Size"
                                                    class="dps-select">
                                                <option value="Small">Small</option>
                                                <option value="Average" selected>Average</option>
                                                <option value="Large">Large</option>
                                            </select>
                                        </div>
                                        <div>
                                            <label class="dps-form-label">Tags</label>
                                            <div class="tags-container d-flex flex-wrap gap-1 mb-2"></div>
                                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                                <select class="tag-select dps-select">
                                                    <option value="">Select a tag...</option>
                                                </select>
                                                <div class="tag-input-wrapper">
                                                    <input type="text" class="custom-tag-input dps-input" placeholder="Or type a custom tag..." />
                                                    <button type="button" class="add-tag-btn dps-add-tag-btn">
                                                        <h4 class="buttonText">Add</h4>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="dps-btn-row">
                                        <button type="button"
                                                class="dps-cancel-btn"
                                                data-action="cancel-regenerate"
                                                data-meal-id="@meal.MealId">
                                            Cancel
                                        </button>
                                        <button type="button"
                                                class="dps-submit-btn"
                                                data-action="submit-regenerate"
                                                data-meal-id="@meal.MealId">
                                            <h4 class="buttonText">Regenerate</h4>
                                        </button>
                                    </div>
                                </form>
                            </div>

                            <button type="button"
                                    class="dps-regen-meal-btn"
                                    data-action="regenerate-meal"
                                    data-meal-id="@meal.MealId">
                                <i class="ti ti-refresh"></i>
                                Regenerate
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="dps-footer">
        <button type="button" class="dps-back-btn" onclick="location.href='@Url.Action("Index", "Home")'">
            <i class="ti ti-arrow-left"></i>
            Back to Planner
        </button>
    </div>

</div>

@section Scripts {
    <script src="~/js/dayPlanSummary.js" asp-append-version="true"></script>
}
