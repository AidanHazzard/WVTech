@model MealPlanner.ViewModels.DayPlanSummaryViewModel
@using MealPlanner.Models
@{
    ViewData["Title"] = "Day Plan Summary";
}

<div class="back1">
    <h2 class="back1Title">Day Plan — @Model.Date.ToString("MMMM d")</h2>
    <hr />

    <div id="day-plan-summary">
        @if (!Model.Meals.Any())
        {
            <p>No meals were generated. Please try again.</p>
        }
        else
        {
            foreach (var meal in Model.Meals)
            {
                <div class="back2 mb-3 p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 data-meal-name data-meal-id="@meal.MealId">@meal.Title</h4>
                        <button type="button"
                                class="buttonBlue"
                                style="position:relative; width:auto; padding:4px 16px; margin-top:0;"
                                data-action="regenerate-meal"
                                data-meal-id="@meal.MealId">
                            Regenerate
                        </button>
                    </div>

                    @if (meal.Recipes.Any())
                    {
                        <ul class="mt-2">
                            @foreach (var recipe in meal.Recipes)
                            {
                                <li>@recipe.Name (@recipe.Calories cal)</li>
                            }
                        </ul>
                    }

                    <!-- Inline regenerate form (toggled by dayPlanSummary.js) -->
                    <div id="regenerate-form-@meal.MealId" style="display:none" class="mt-3">
                        <form action="/Meal/RegenerateMeal?mealId=@meal.MealId" method="POST">
                            @Html.AntiForgeryToken()

                            <div class="row g-3 mb-3">
                                <div class="col-md-4">
                                    <label class="form-label">Meal size</label>
                                    <select name="Size"
                                            data-regen-field="size"
                                            id="regen-@meal.MealId-Size"
                                            class="form-control">
                                        <option value="Small">Small</option>
                                        <option value="Average" selected>Average</option>
                                        <option value="Large">Large</option>
                                    </select>
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label">Food type (tags)</label>
                                    <select name="TagIds"
                                            id="regen-@meal.MealId-TagIds"
                                            class="form-control"
                                            multiple>
                                        @foreach (var tag in Model.AvailableTags)
                                        {
                                            <option value="@tag.Id">@tag.Name</option>
                                        }
                                    </select>
                                    <input name="CustomTagName"
                                           class="form-control mt-2"
                                           placeholder="Or type a custom tag…" />
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary">Regenerate</button>
                            <button type="button"
                                    class="btn btn-secondary ms-2"
                                    data-action="cancel-regenerate"
                                    data-meal-id="@meal.MealId">
                                Cancel
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>

    <a asp-action="PlannerHome" class="buttonBlue mt-3 d-inline-block">
        <h4 class="buttonText">Back to Planner</h4>
    </a>
</div>

@section Scripts {
    <script src="~/js/dayPlanSummary.js"></script>
}
