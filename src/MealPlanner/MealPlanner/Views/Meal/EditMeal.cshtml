@model MealPlanner.ViewModels.EditMealViewModel

<link rel="stylesheet" href="~/css/newMeal.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/editMeal.css" asp-append-version="true" />

<!-- Top bar: Back -->
<div class="em-top-bar">
    <a href="@(ViewBag.ReturnUrl ?? Url.Action("ViewMeal", "Meal", new { id = Model.Id }))" class="em-back-link">
        <i class="ti ti-arrow-left"></i>
        Back
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success" style="margin-bottom:12px; padding:10px 14px; border-radius:6px; background:rgba(46,201,154,0.12); border:0.5px solid rgba(46,201,154,0.4); color:#2EC99A; font-size:13px;">
        @TempData["SuccessMessage"]
    </div>
}

<!-- Page heading -->
<div class="em-page-heading">
    <div class="em-page-title">Edit meal</div>
    <p class="em-page-subtitle">Update your meal details</p>
</div>

<!-- Meal details card -->
<form id="editMealForm" asp-action="EditMeal" method="POST">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="em-card">
        <div class="em-card-title-row">
            <div class="em-card-title-icon"><i class="ti ti-calendar"></i></div>
            <span class="em-card-title-text">Meal details</span>
        </div>

        <div class="em-form-grid">
            <div class="em-field">
                <label class="em-label" asp-for="Title">Title</label>
                <input asp-for="Title" id="mealTitle" class="em-input" placeholder="e.g. Lunch" />
                <span asp-validation-for="Title" class="text-danger" style="font-size:11px"></span>
            </div>
            <div class="em-field">
                <label class="em-label" asp-for="SelectedMonth">Month</label>
                <select asp-for="SelectedMonth" class="em-input em-select">
                    <option value="">Month</option>
                    @for (int i = 1; i <= 12; i++)
                    {
                        <!option @(i == Model.SelectedMonth ? "selected" : "") value="@i">
                            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                        </!option>
                    }
                </select>
                <span asp-validation-for="SelectedMonth" class="text-danger" style="font-size:11px"></span>
            </div>
            <div class="em-field">
                <label class="em-label" asp-for="SelectedDay">Day</label>
                <select asp-for="SelectedDay" class="em-input em-select">
                    <option value="">Day</option>
                    @for (int i = 1; i <= 31; i++)
                    {
                        <!option value="@i" @(i == Model.SelectedDay ? "selected" : "")>@i</!option>
                    }
                </select>
                <span asp-validation-for="SelectedDay" class="text-danger" style="font-size:11px"></span>
            </div>
        </div>

        <!-- Repeat weekly toggle -->
        <input asp-for="RepeatWeekly" id="repeatWeeklyToggle" type="checkbox" style="position:absolute; width:1px; height:1px; overflow:hidden;" />
        <div class="em-toggle-row">
            <span class="em-toggle-label">Repeat weekly</span>
            <div class="em-toggle-switch @(Model.RepeatWeekly ? "on" : "")" id="emRepeatToggle">
                <div class="em-toggle-knob"></div>
            </div>
        </div>

        <!-- Repeat on days (slides open when toggle is on) -->
        <div id="repeatDaysPanel" class="@(Model.RepeatWeekly ? "open" : "")">
            <div class="em-days-row">
                @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                {
                    <label class="em-day-chip @(Model.RepeatDays.Contains(day) ? "on" : "")"
                           data-day="@((int)day)"
                           style="position:relative;">
                        <input type="checkbox"
                               id="repeatDay_@day"
                               name="RepeatDays"
                               value="@((int)day)"
                               class="repeat-day-checkbox"
                               @(Model.RepeatDays.Contains(day) ? "checked" : "")
                               style="position:absolute; width:1px; height:1px; overflow:hidden;" />
                        @day.ToString().Substring(0, 3)
                    </label>
                }
            </div>
        </div>
    </div>

    <!-- Current recipes card -->
    <div class="em-card">
        <div class="em-card-title-row">
            <div class="em-card-title-icon"><i class="ti ti-bowl-chopsticks"></i></div>
            <span class="em-card-title-text">Recipes in this meal</span>
        </div>

        <div id="mealRecipeList">
            @if (Model.Recipes != null && Model.Recipes.Any())
            {
                @foreach (var recipe in Model.Recipes)
                {
                    <div class="em-recipe-row mealRecipeItem" data-id="@recipe.Id">
                        <h4 class="em-recipe-name">@recipe.Name</h4>
                        <div class="em-recipe-actions">
                            <button type="button"
                                    class="em-recipe-remove-btn delete-recipe-btn"
                                    data-id="@recipe.Id"
                                    title="Remove recipe">
                                <i class="ti ti-x"></i>
                            </button>
                        </div>
                        <input type="hidden" name="RecipeIds" value="@recipe.Id" />
                    </div>
                }
            }
            else
            {
                <p class="em-empty-recipes">No recipes in this meal yet.</p>
            }
        </div>
    </div>

    <!-- Search card -->
    <div class="em-card">
        <div class="em-card-title-row">
            <div class="em-card-title-icon"><i class="ti ti-search"></i></div>
            <span class="em-card-title-text">Add recipes</span>
        </div>

        <!-- Search input -->
        <div class="em-search-input-wrapper">
            <i class="ti ti-search em-search-icon"></i>
            <input id="searchText" class="em-search-input" type="text"
                   placeholder="Search recipes…" autocomplete="off" />
        </div>

        <!-- Tag filter chips — populated by editMeal.js / recipeSearch.js -->
        <div class="search-tag-chips" id="tagFilterChips" style="margin-bottom:10px"></div>
        <select id="tagFilter" style="display:none"><option value="">All</option></select>

        <div id="error" style="font-size:13px; color:var(--muted-text); min-height:0"></div>

        <!-- Recipe results -->
        <div id="recipeResults" style="display:flex; flex-direction:column; gap:6px; margin-top:4px"></div>

        <button type="button" id="addSelectedRecipesBtn" class="nm-add-selected-btn" style="display:none">
            Add selected
        </button>

        <!-- Recipe result template -->
        <template id="recipeResult">
            <div class="recipeSearchRow" externaluri="">
                <img class="recipe-thumbnail" src="" alt="" />
                <div class="recipe-row-info">
                    <div class="recipeName"></div>
                    <div class="recipeTags"></div>
                    <div hidden class="recipeId"></div>
                    <input type="hidden" class="recipeIdInput" value="" />
                    <div class="recipeRating"></div>
                </div>
                <div class="em-add-indicator">
                    <i class="ti ti-plus em-indicator-plus"></i>
                    <i class="ti ti-check em-indicator-check"></i>
                </div>
                <div class="row-end" style="display:none"></div>
            </div>
        </template>

        <img src="~/images/icons/Edamam_Badge.svg" class="edamam-badge" width="200" height="100" />
    </div>

    <!-- Action bar save button (inside editMealForm so it submits it) -->
    <div style="display:none">
        <button type="submit" id="saveMealBtnInner"></button>
    </div>

</form>

<!-- Action bar (outside editMealForm so delete form is not nested) -->
<div class="em-action-bar">
    <a href="@(ViewBag.ReturnUrl ?? Url.Action("ViewMeal", "Meal", new { id = Model.Id }))" class="em-action-cancel">Cancel</a>
    <form asp-action="DeleteMeal" asp-controller="Meal" method="post" class="m-0">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <input type="hidden" name="source" value="home" />
        <button type="button" class="em-delete-btn btn-delete-meal">
            <i class="ti ti-trash"></i>
            Delete meal
        </button>
    </form>
    <button type="submit" class="em-action-save" id="saveMealBtn" form="editMealForm">
        <i class="ti ti-check"></i>
        Save changes
    </button>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module" src="~/js/recipeSearch.js"></script>
    <script type="module" src="~/js/editMeal.js"></script>
}
