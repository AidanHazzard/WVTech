@model MealPlanner.ViewModels.EditMealViewModel
@{DateTime today = DateTime.Today; }

<div class="back1 backHasButton">

    <!-- Top bar: Back + Delete -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a href="@Url.Action("ViewMeal", "Meal", new { id = Model.Id })" class="btn btn-outline-secondary back1Title">
            &larr; Back
        </a>

        <form asp-action="DeleteMeal" asp-controller="Meal" method="post"
              onsubmit="return confirm('Are you sure you want to delete this meal?');" class="m-0">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
        </form>
    </div>

    <h2 class="back1Title">Edit Meal</h2>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            Meal updated successfully
        </div>
    }
    <hr>
    <!-- Form for the meal details only -->
    <form id="editMealForm" class="mx-1" asp-action="EditMeal" method="POST">

        <input type="hidden" asp-for="Id" />

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label asp-for="Title" class="form-label back1Title"></label>
                <input asp-for="Title" id="mealTitle" class="form-control mealInput" placeholder="Meal title" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Date" class="form-label back1Title">Date</label>
                <input type="date" asp-for="Date" name="Date" class="form-control mealInput" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Time" class="form-label back1Title">Time</label>
                <input type="time" asp-for="Time" name="Time" class="form-control mealInput" />
                <span asp-validation-for="Time" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="SelectedMonth" class="form-label back1Title">Month</label>
                <select asp-for="SelectedMonth" class="form-control mealSelect">
                    <option value="">Select month</option>
                    @for (int i = 1; i <= 12; i++)
                    {
                        <!option @(i==today.Month ? "selected" : "") value="@i">
                            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                        </!option>
                    }
                </select>
                <span asp-validation-for="SelectedMonth" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="SelectedDay" class="form-label back1Title">Day</label>
                <select asp-for="SelectedDay" class="form-control mealSelect">
                    <option value="">Select day</option>
                    @for (int i = 1; i <= 31; i++)
                    {
                        <!option value="@i" @(i==today.Day ? "selected" : "")>@i</!option>
                    }
                </select>
                <span asp-validation-for="SelectedDay" class="text-danger"></span>
            </div>

            <div class="col-md-4 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="RepeatWeekly" class="form-check-input" />
                    <label asp-for="RepeatWeekly" class="form-check-label back1Title">
                        Repeat Weekly
                    </label>
                </div>
            </div>
        </div>

        <!-- Hidden inputs for model binding -->
        @* <div id="recipe-id-container">
            @foreach (var recipe in Model.Recipes)
            {
                <input type="hidden" name="RecipeIds" value="@recipe.Id" />
            }
        </div> *@

        <!-- Visible recipe list -->
        <div id="mealRecipeList" class="mb-3">
            @if (Model.Recipes != null && Model.Recipes.Any())
            {
                @foreach (var recipe in Model.Recipes)
                {
                    var location = Url.Action("Recipes", "FoodEntries", new { id = recipe.Id });
                    <div class="mealRecipeItem d-flex align-items-center justify-content-between mb-2 back2 back2-textbox"
                         data-id="@recipe.Id"
                         style="cursor:pointer;"
                         onclick="location.href='@location'">
                        <h4 class="buttonText mb-0">@recipe.Name</h4>
                        <button type="button" class="btn btn-danger delete-recipe-btn" data-id="@recipe.Id" onclick="event.stopPropagation()">
                            X
                        </button>
                        <input type="hidden" name="RecipeIds" value="@recipe.Id" />
                    </div>
                }
            }
            else
            {
                <p class="text-muted mb-3">There are no recipes in this meal yet.</p>
            }
        </div>

        <button type="submit" class="buttonBlue mt-3">
            <h2 class="buttonText">Save Changes</h2>
        </button>
    </form>

    <div class="back2 pe-5 mt-3">
        <h3 class="back1Title">Search for Recipes to Add</h3>
        @await Html.PartialAsync("_RecipeSearchPartial")
    </div>

</div>

@section Scripts {
    <script src="~/js/recipeSearch.js"></script>
}