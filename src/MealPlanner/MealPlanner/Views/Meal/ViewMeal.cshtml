@model MealPlanner.Models.Meal

@{
    var title      = Model.Title ?? "Meal";
    var lower      = title.ToLower();
    var mealIcon   = lower.Contains("breakfast") ? "ti-sun"
                   : lower.Contains("dinner")    ? "ti-moon"
                   : "ti-sun-high";

    var dateStr    = Model.StartTime?.ToString("MMM d, yyyy") ?? "No date set";
    var timeStr    = Model.StartTime?.ToString("h:mm tt") ?? "";
    var endTimeStr = Model.EndTime?.ToString("h:mm tt");
    var dateLabel  = string.IsNullOrEmpty(timeStr)
                        ? dateStr
                        : endTimeStr != null
                            ? $"{dateStr} · {timeStr} – {endTimeStr}"
                            : $"{dateStr} · {timeStr}";
}

<link rel="stylesheet" href="~/css/viewMeal.css" asp-append-version="true" />

<!-- Back link -->
<a href="@Url.Action("Index", "Home", new { id = Model.Id })" class="vm-back-link">
    <i class="ti ti-arrow-left"></i>
    Back
</a>

<!-- Page header -->
<div class="vm-header">
    <div class="vm-header-icon">
        <i class="ti @mealIcon"></i>
    </div>
    <div>
        <h1 class="vm-meal-name">@title</h1>
        <div class="vm-meal-date">
            @dateLabel
            @if (!string.IsNullOrWhiteSpace(Model.RepeatRule))
            {
                <span style="margin-left:8px; padding:2px 8px; border-radius:9999px; background:rgba(20,184,166,0.1); border:0.5px solid rgba(20,184,166,0.3); font-size:11px; color:#2EC99A;">
                    @Model.RepeatRule
                </span>
            }
        </div>
    </div>
</div>

<!-- Recipes card -->
<div class="vm-card">
    <div class="vm-card-title-row">
        <div class="vm-card-title-icon">
            <i class="ti ti-bowl-chopsticks"></i>
        </div>
        <span class="vm-card-title-text">Recipes in this meal</span>
    </div>

    @if (Model.Recipes != null && Model.Recipes.Any())
    {
        @foreach (var recipe in Model.Recipes)
        {
            <div class="vm-recipe-row mealRecipeItem"
                 data-recipe-id="@recipe.Id"
                 data-meal-id="@Model.Id">
                <span class="vm-recipe-name">@recipe.Name</span>
                <div class="vm-recipe-actions">
                    @if (Model.Recipes.Count > 1)
                    {
                        <button type="button"
                                class="vm-regen-btn"
                                data-action="regenerate-recipe"
                                data-recipe-id="@recipe.Id"
                                data-meal-id="@Model.Id"
                                title="Regenerate this recipe">
                            <i class="ti ti-refresh"></i>
                        </button>
                    }
                    <button type="button"
                            class="vm-remove-btn delete-recipe-btn"
                            title="Remove this recipe">
                        <i class="ti ti-x"></i>
                    </button>
                </div>
            </div>
        }
    }
    else
    {
        <p class="vm-empty">There are no recipes in this meal.</p>
    }
</div>

<!-- Regen feedback banners -->
<div id="regen-no-alt-msg" data-regen-no-alternative class="vm-alert vm-alert-warning" style="display:none">
    <i class="ti ti-alert-triangle"></i>
    No alternative recipe is available right now.
</div>

<div id="regen-undo-toast" class="vm-alert vm-alert-success" style="display:none">
    <i class="ti ti-check"></i>
    <span>Recipe replaced.</span>
    <button type="button" class="vm-undo-btn" data-action="undo-regenerate-recipe">Undo</button>
</div>

<!-- Action bar -->
<div class="vm-action-bar">
    <a href="@Url.Action("Index", "Home", new { id = Model.Id })" class="vm-action-back">
        <i class="ti ti-arrow-left"></i>
        Back
    </a>
    <a href="@Url.Action("EditMeal", "Meal", new { id = Model.Id })" class="vm-action-edit">
        <i class="ti ti-edit"></i>
        Edit Meal
    </a>
</div>

@section Scripts {
    <script src="~/js/viewMeal.js"></script>
}
