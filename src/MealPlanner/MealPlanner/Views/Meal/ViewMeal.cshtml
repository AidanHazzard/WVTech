@model MealPlanner.Models.Meal

<h1>Meal @Model.Id</h1>

@if (Model.StartTime.HasValue)
{
    <p>Time: @Model.StartTime.Value.ToString("MMM dd, yyyy HH:mm")</p>
}

@if (Model.Recipes != null && Model.Recipes.Any())
{
    <ul>
    @foreach (var recipe in Model.Recipes)
    {
        <li>@recipe.Name</li>
    }
    </ul>
}
else
{
    <p>No recipes for this meal yet.</p>
}

<a asp-controller="Meal" asp-action="PlannerHome">Back to Planner</a>