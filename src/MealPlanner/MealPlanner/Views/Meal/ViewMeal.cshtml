@model MealPlanner.Models.Meal

<!-- Title-->
<div class="back1 backHasButton">

    <!-- Back Button Top Left, inline with layout -->
    <div class="mb-3">
       <a href="@Url.Action("Index", "Home", new { id = Model.Id })" 
   class="btn btn-outline-secondary back1Title">
    &larr; Back
</a>
    </div>

    <div class="flex-grow-1 text-center">
        <h2 id="mealTitle" class="back1Title">@Model.Title</h2>
        <div class="back1Title">
            <!-- Show date first -->
            @(Model.StartTime?.ToString("MMM dd, yyyy") ?? "No date set")

            <!-- Show time -->
            @(Model.StartTime?.ToString("h:mm tt") ?? "No time set")

            @if (Model.EndTime.HasValue)
            {
                <span>– @Model.EndTime.Value.ToString("h:mm tt")</span>
            }
            <!-- Show repeat badge -->
            @if (!string.IsNullOrWhiteSpace(Model.RepeatRule))
            {
                <span class="badge bg-info ms-2">@Model.RepeatRule</span>
            }
        </div>
        <hr>
    </div>

    <!-- Meal info -->
 @if (Model.Recipes != null && Model.Recipes.Any())
{
    <div class="list-group">
        @foreach (var recipe in Model.Recipes)
        {
            var location = Url.Action("Recipes", "FoodEntries", new { id = recipe.Id });
            <div class="mealRecipeItem d-flex align-items-center justify-content-between mb-2 back2 back2-textbox"
                 data-recipe-id="@recipe.Id"
                 data-meal-id="@Model.Id"
                 style="cursor:pointer;"
                 onclick="location.href='@location'">
                <h4 class="buttonText mb-0">@recipe.Name</h4>
                <button type="button" class="btn btn-danger delete-recipe-btn">X</button>
            </div>
        }
    </div>
}
 else
    {
        <p class="text-muted mb-0">There are no recipes in this meal.</p>
    }

    <form asp-controller="Meal" asp-action="EditMeal" method="get">
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="buttonBlue">
            <h2 class="buttonText">Edit Meal</h2>
        </button>
    </form>

</div>

@section Scripts {
    <script src="~/js/viewMeal.js"></script>
}