@model MealPlanner.Models.Meal

<div class="back1">

    <!-- Header -->
    <div class="back2">
        <div class="d-flex align-items-center">

          

            <!-- Title + time -->
            <div class="flex-grow-1 text-center">
                <h2 class="mb-1">Meal Details</h2>

                <div class="text-muted small">
                    @(Model.StartTime?.ToString("h:mm tt") ?? "No time set")

                    @if (Model.EndTime.HasValue)
                    {
                        <span>– @Model.EndTime.Value.ToString("h:mm tt")</span>
                    }

                    @if (Model.RepeatRule == "Weekly")
                    {
                        <span class="badge bg-info ms-2">Weekly</span>
                    }
                </div>
            </div>

        </div>
    </div>

    <!-- Meal info -->
    <div class="back2 mt-3 p-3">
        <h4 class="mb-3">Recipes</h4>

        @if (Model.Recipes != null && Model.Recipes.Any())
        {
            <div class="list-group">
                @foreach (var recipe in Model.Recipes)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-semibold">@recipe.Name</span>

                        <a asp-controller="Recipe"
                           asp-action="Details"
                           asp-route-id="@recipe.Id"
                           class="btn btn-sm btn-outline-secondary">
                            View
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No recipes attached to this meal.</p>
        }
    </div>

</div>