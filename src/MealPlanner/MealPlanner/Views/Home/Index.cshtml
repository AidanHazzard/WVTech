@model MealPlanner.ViewModels.PlannerHomeViewModel

<link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
<p id="modelsDate" hidden>@Model.SelectedDate</p>


<div class="back1Dates">
    <button class="Arrow" id="ALeft">
        <img src="~/images/icons/arrow.png" alt="arrow" draggable="false">
    </button>

    <div id="back1DatesInnerContainer">

    </div>

    <button class="Arrow" id="ARight">
        <img src="~/images/icons/arrow.png" alt="arrow" draggable="false">
    </button>
</div>

<div class="back1 backHasButton">
    <h1 class="back1Title">
        Meals On @Model.SelectedDate.ToString("MMM")/@Model.SelectedDate.Day/@Model.SelectedDate.ToString("yy")
    </h1>

    <div class="row align-items-center">
        <div class="col d-flex justify-content-center flex-wrap gap-3">

        @if (@Model.Meals.Count == 0)
        {
            <div class="back2">
                <h2 class="back1Title">You are yet to add a meal to this day.</h2>
            </div>
        }

        @foreach (Meal meal in Model.Meals)
        {
            <div class="mealCardWrapper">

                <!-- Delete meal button (red X in top-right corner of card) -->
                <form asp-controller="Meal" asp-action="DeleteMeal" method="post" class="mealDeleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@meal.Id" />
                    <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="source" value="home" />
                    <button type="submit" class="mealDeleteButton" title="Delete meal">✕</button>
                </form>

                <!-- Meal card container -->
                <div class="mealCardInner">

                    <!-- Checkbox (toggles completion) -->
                    <form asp-controller="Meal" asp-action="ToggleMealCompleted" method="post" class="mealCompleteForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@meal.Id" />
                        <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="source" value="home" />

                        <input type="checkbox"
                               name="isCompleted"
                               value="true"
                               class="MealCheckBox"
                               @(meal.IsCompleted ? "checked" : null)
                               onchange="this.form.submit(); event.stopPropagation();" />
                    </form>

                    <!-- Meal card button (opens the meal view) -->
                    <form asp-controller="Meal" asp-action="ViewMeal" method="get" class="mealViewForm">
                        <input type="hidden" name="id" value="@meal.Id" />

                        <button type="submit" class="imageButton mealButton">
                            @{
                                var sortedRecipes = meal.Recipes
                                    .OrderByDescending(r => r.Calories)
                                    .ToList();
                            }
                            @if (sortedRecipes.Any())
                            {
                                <div class="d-flex fullImage recipe-collage" style="overflow:hidden;">
                                    @{
                                        double widthPct = 50.0;
                                    }
                                    @foreach (var r in sortedRecipes)
                                    {
                                        bool rHasImage = !string.IsNullOrEmpty(r.ImageUrl);
                                        string rSrc = rHasImage ? r.ImageUrl! : "/images/placeholder/no-image.svg";
                                        <img src="@rSrc"
                                             alt="@r.Name"
                                             data-calories="@r.Calories"
                                             data-recipe-id="@r.Id"
                                             class="recipe-collage-img @(rHasImage ? "recipe-has-image" : "recipe-no-image")"
                                             style="width:@widthPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%; flex-shrink:0; object-fit:cover; height:100%;" />
                                        widthPct /= 2.0;
                                    }
                                </div>
                            }
                            else
                            {
                                <img src="~/images/placeholder/apples.avif"
                                     alt="apples"
                                     class="fullImage">
                            }

                            <div class="buttonGreen noBevelTop">
                                <h2 class="buttonText">@meal.Title</h2>
                            </div>
                        </button>
                    </form>

                </div>

            </div>
        }

    </div>

        <div class="back2">
            <h2 class="back1Title">Statistics</h2>

            @if (Model.NutritionBar != null)
            {
                <partial name="_NutritionBarDisplayPartial" model="Model.NutritionBar" />
            }
            else
            {
                <img src="~/images/placeholder/nutrients.png" alt="nutrients" class="imageFit">
            }
        </div>
    </div>

    <form asp-controller="Meal" asp-action="SelectMeal" method="get">
        <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
        <button class="buttonBlue">
            <h2 class="buttonText">Select A Meal</h2>
        </button>
    </form>
</div>

@section Scripts {
    <script src="~/js/indexPlanner.js"></script>
}